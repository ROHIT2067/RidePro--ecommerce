<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Report - Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #f5f6fa;
      color: #2c3e50;
    }

    .dashboard-container {
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar Styles */
    .sidebar {
      width: 250px;
      background-color: #ffffff;
      border-right: 1px solid #e5e7eb;
      padding: 20px 0;
      position: fixed;
      height: 100vh;
      overflow-y: auto;
    }

    .logo {
      padding: 0 20px 30px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 20px;
      font-weight: 700;
      color: #1a1a1a;
    }

    .logo i {
      font-size: 24px;
    }

    .nav-menu {
      list-style: none;
    }

    .nav-item {
      margin-bottom: 5px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: #6b7280;
      text-decoration: none;
      transition: all 0.3s ease;
      font-size: 14px;
    }

    .nav-link:hover {
      background-color: #f9fafb;
      color: #1a1a1a;
    }

    .nav-link.active {
      background-color: #f3f4f6;
      color: #1a1a1a;
      font-weight: 500;
      border-left: 3px solid #3b82f6;
    }

    .nav-link i {
      width: 20px;
      text-align: center;
      font-size: 16px;
    }

    /* Main Content */
    .main-content {
      margin-left: 250px;
      flex: 1;
      padding: 30px 40px;
    }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 30px;
      font-size: 14px;
      color: #6b7280;
    }

    .breadcrumb-separator {
      color: #d1d5db;
    }

    .breadcrumb-active {
      color: #1a1a1a;
      font-weight: 500;
    }

    /* Page Header */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .page-title {
      font-size: 28px;
      font-weight: 700;
      color: #1a1a1a;
    }

    /* Filter Bar */
    .filter-bar {
      background-color: #ffffff;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e5e7eb;
      margin-bottom: 30px;
    }

    .filter-section {
      margin-bottom: 20px;
    }

    .filter-label {
      font-size: 14px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 8px;
      display: block;
    }

    .quick-filters {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .quick-filter-btn {
      padding: 8px 16px;
      border: 1px solid #d1d5db;
      background-color: #ffffff;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.3s ease;
    }

    .quick-filter-btn:hover {
      background-color: #f9fafb;
    }

    .quick-filter-btn.active {
      background-color: #3b82f6;
      color: #ffffff;
      border-color: #3b82f6;
    }

    .date-inputs {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .date-input {
      padding: 8px 12px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 14px;
    }

    .status-filters {
      margin-bottom: 20px;
    }

    .status-select {
      padding: 8px 12px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 14px;
      background-color: #ffffff;
      min-width: 200px;
      cursor: pointer;
    }

    .status-select:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .filter-summary {
      background-color: #f0f9ff;
      border: 1px solid #0ea5e9;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 24px;
    }

    .filter-info {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #0c4a6e;
      font-size: 14px;
    }

    .filter-info i {
      color: #0ea5e9;
    }

    .filter-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .btn {
      padding: 10px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-primary {
      background-color: #3b82f6;
      color: #ffffff;
      border: 1px solid #3b82f6;
    }

    .btn-primary:hover {
      background-color: #2563eb;
    }

    .btn-secondary {
      background-color: #ffffff;
      color: #374151;
      border: 1px solid #d1d5db;
    }

    .btn-secondary:hover {
      background-color: #f9fafb;
    }

    /* Summary Cards */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .summary-card {
      background-color: #ffffff;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e5e7eb;
    }

    .summary-card h3 {
      font-size: 14px;
      font-weight: 500;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .summary-value {
      font-size: 28px;
      font-weight: 700;
      color: #1a1a1a;
    }

    /* Orders Table */
    .orders-section {
      background-color: #ffffff;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e5e7eb;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: #1a1a1a;
    }

    .download-buttons {
      display: flex;
      gap: 12px;
    }

    .orders-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }

    .orders-table thead th {
      text-align: left;
      padding: 12px 16px;
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid #e5e7eb;
      background-color: #f9fafb;
    }

    .orders-table tbody td {
      padding: 16px;
      font-size: 14px;
      color: #1a1a1a;
      border-bottom: 1px solid #f3f4f6;
    }

    .orders-table tbody tr:hover {
      background-color: #f9fafb;
    }

    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 500;
    }

    .status-processing, .status-pending, .status-confirmed {
      background-color: #fef3c7;
      color: #92400e;
    }

    .status-delivered {
      background-color: #d1fae5;
      color: #065f46;
    }

    .status-cancelled {
      background-color: #fee2e2;
      color: #991b1b;
    }

    .status-returned, .status-return-requested {
      background-color: #fde68a;
      color: #92400e;
    }

    .status-partially-returned {
      background-color: #fed7aa;
      color: #9a3412;
    }

    .coupon-yes {
      color: #059669;
      font-weight: 500;
    }

    .coupon-no {
      color: #dc2626;
      font-weight: 500;
    }

    .payment-method {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 500;
    }

    .payment-cod {
      background-color: #fef3c7;
      color: #92400e;
    }

    .payment-wallet {
      background-color: #dbeafe;
      color: #1e40af;
    }

    .payment-online {
      background-color: #d1fae5;
      color: #065f46;
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 20px;
    }

    .pagination-btn {
      padding: 8px 12px;
      border: 1px solid #d1d5db;
      background-color: #ffffff;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      text-decoration: none;
      color: #374151;
      transition: all 0.3s ease;
    }

    .pagination-btn:hover {
      background-color: #f9fafb;
    }

    .pagination-btn.active {
      background-color: #3b82f6;
      color: #ffffff;
      border-color: #3b82f6;
    }

    .pagination-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
      }

      .main-content {
        margin-left: 0;
        padding: 20px;
      }

      .summary-grid {
        grid-template-columns: 1fr;
      }

      .quick-filters {
        flex-direction: column;
      }

      .date-inputs {
        flex-direction: column;
        align-items: stretch;
      }

      .status-select {
        min-width: auto;
        width: 100%;
      }

      .orders-table {
        font-size: 12px;
      }

      .orders-table th,
      .orders-table td {
        padding: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <%- include('partials/admin_sidebar') %>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <span>Admin</span>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-active">Sales Report</span>
      </div>

      <!-- Page Header -->
      <div class="page-header">
        <h1 class="page-title">Sales Report</h1>
      </div>

      <!-- Success/Error Messages -->
      <% if (success_msg && success_msg.length > 0) { %>
        <div style="background-color: #d1fae5; color: #065f46; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #10b981;">
          <%= success_msg %>
        </div>
      <% } %>
      
      <% if (error_msg && error_msg.length > 0) { %>
        <div style="background-color: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #ef4444;">
          <%= error_msg %>
        </div>
      <% } %>

      <!-- Filter Bar -->
      <div class="filter-bar">
        <form id="filterForm" method="GET" action="/admin/reports" novalidate>
          <div class="filter-section">
            <label class="filter-label">Quick Filters</label>
            <div class="quick-filters">
              <button type="button" class="quick-filter-btn <%= currentRange === 'daily' ? 'active' : '' %>" data-range="daily">Daily</button>
              <button type="button" class="quick-filter-btn <%= currentRange === 'weekly' ? 'active' : '' %>" data-range="weekly">Weekly</button>
              <button type="button" class="quick-filter-btn <%= currentRange === 'monthly' ? 'active' : '' %>" data-range="monthly">Monthly</button>
              <button type="button" class="quick-filter-btn <%= currentRange === 'yearly' ? 'active' : '' %>" data-range="yearly">Yearly</button>
            </div>
          </div>

          <div class="filter-section">
            <label class="filter-label">Custom Date Range</label>
            <div class="date-inputs">
              <input type="date" name="startDate" class="date-input" value="<%= startDate %>" id="startDate">
              <span>to</span>
              <input type="date" name="endDate" class="date-input" value="<%= endDate %>" id="endDate">
            </div>
          </div>

          <div class="filter-section">
            <label class="filter-label">Order Status</label>
            <div class="status-filters">
              <select name="status" class="status-select" id="statusSelect">
                <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Orders</option>
                <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>Active Orders</option>
                <option value="completed" <%= currentStatus === 'completed' ? 'selected' : '' %>>Delivered</option>
                <option value="Pending" <%= currentStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
                <option value="Confirmed" <%= currentStatus === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
                <option value="Processing" <%= currentStatus === 'Processing' ? 'selected' : '' %>>Processing</option>
                <option value="Shipped" <%= currentStatus === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                <option value="Out for Delivery" <%= currentStatus === 'Out for Delivery' ? 'selected' : '' %>>Out for Delivery</option>
                <option value="cancelled" <%= currentStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                <option value="returned" <%= currentStatus === 'returned' ? 'selected' : '' %>>Returned/Return Requested</option>
              </select>
            </div>
          </div>

          <div class="filter-actions">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-search"></i>
              Apply Filters
            </button>
          </div>
        </form>
      </div>

      <!-- Filter Summary -->
      <% if (currentStatus && currentStatus !== 'all') { %>
        <div class="filter-summary">
          <div class="filter-info">
            <i class="fas fa-filter"></i>
            <span>Showing orders with status: 
              <strong>
                <% if (currentStatus === 'active') { %>
                  Active Orders (Excluding Cancelled/Returned)
                <% } else if (currentStatus === 'completed') { %>
                  Completed (Delivered)
                <% } else if (currentStatus === 'cancelled') { %>
                  Cancelled
                <% } else if (currentStatus === 'returned') { %>
                  Returned/Return Requested
                <% } else { %>
                  <%= currentStatus %>
                <% } %>
              </strong>
            </span>
          </div>
        </div>
      <% } %>

      <!-- Summary Cards -->
      <div class="summary-grid">
        <div class="summary-card">
          <h3>Overall Sales Count</h3>
          <div class="summary-value"><%= summary.totalOrders %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Total number of completed orders</p>
        </div>
        <div class="summary-card">
          <h3>Order Amount</h3>
          <div class="summary-value">₹<%= summary.totalOrderAmount.toLocaleString('en-IN') %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Total revenue before any discounts</p>
        </div>
        <div class="summary-card">
          <h3>Total Discounts</h3>
          <div class="summary-value">₹<%= summary.totalDiscount.toLocaleString('en-IN') %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Total amount discounted via coupons</p>
        </div>
        <div class="summary-card">
          <h3>Net Revenue</h3>
          <div class="summary-value">₹<%= summary.totalNetRevenue.toLocaleString('en-IN') %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Final revenue after all discounts</p>
        </div>
        <div class="summary-card">
          <h3>Total Refunds</h3>
          <div class="summary-value" style="color: #ef4444;">₹<%= summary.totalRefunds.toLocaleString('en-IN') %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Total amount refunded to customers</p>
        </div>
        <div class="summary-card">
          <h3>Actual Revenue</h3>
          <div class="summary-value" style="color: #10b981;">₹<%= summary.actualRevenue.toLocaleString('en-IN') %></div>
          <p style="font-size: 12px; color: #6b7280; margin-top: 8px;">Net revenue after refunds</p>
        </div>
      </div>

      <!-- Orders Table -->
      <div class="orders-section">
        <div class="section-header">
          <h2 class="section-title">Detailed Sales</h2>
          <div class="download-buttons">
            <% 
              let downloadParams = currentRange !== 'custom' ? 
                `range=${currentRange}` : 
                `startDate=${startDate}&endDate=${endDate}`;
              
              // Add status parameter if not 'all'
              if (currentStatus && currentStatus !== 'all') {
                downloadParams += `&status=${currentStatus}`;
              }
            %>
            <a href="/admin/reports/download?format=pdf&<%= downloadParams %>" class="btn btn-secondary">
              <i class="fas fa-file-pdf"></i>
              Download PDF
            </a>
            <a href="/admin/reports/download?format=excel&<%= downloadParams %>" class="btn btn-secondary">
              <i class="fas fa-file-excel"></i>
              Download Excel
            </a>
          </div>
        </div>

        <% if (orders && orders.length > 0) { %>
          <table class="orders-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Order Amount</th>
                <th>Refund Amount</th>
                <th>Coupon Applied</th>
                <th>Payment Method</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(order => { %>
                <tr>
                  <td><%= order.orderId %></td>
                  <td><%= new Date(order.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                  <td><%= order.customerName %></td>
                  <td title="<%= order.items %>"><%= order.items.length > 50 ? order.items.substring(0, 50) + '...' : order.items %></td>
                  <td>₹<%= order.orderAmount.toLocaleString('en-IN') %></td>
                  <td style="color: <%= order.refundAmount > 0 ? '#ef4444' : '#6b7280' %>;">
                    ₹<%= order.refundAmount.toLocaleString('en-IN') %>
                  </td>
                  <td>
                    <span class="<%= order.couponApplied === 'Yes' ? 'coupon-yes' : 'coupon-no' %>">
                      <%= order.couponApplied %>
                    </span>
                  </td>
                  <td>
                    <span class="payment-method payment-<%= order.paymentMethod.toLowerCase() %>">
                      <%= order.paymentMethod %>
                    </span>
                  </td>
                  <td>
                    <span class="status-badge status-<%= order.status.toLowerCase().replace(' ', '-') %>">
                      <%= order.status %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <!-- Pagination -->
          <div class="pagination">
            <% 
              const paginationParams = currentRange !== 'custom' ? 
                `range=${currentRange}` : 
                `startDate=${startDate}&endDate=${endDate}`;
            %>
            <% if (pagination.hasPrev) { %>
              <a href="?page=<%= pagination.currentPage - 1 %>&<%= paginationParams %>" class="pagination-btn">
                <i class="fas fa-chevron-left"></i>
                Previous
              </a>
            <% } %>

            <% for (let i = Math.max(1, pagination.currentPage - 2); i <= Math.min(pagination.totalPages, pagination.currentPage + 2); i++) { %>
              <a href="?page=<%= i %>&<%= paginationParams %>" 
                 class="pagination-btn <%= i === pagination.currentPage ? 'active' : '' %>">
                <%= i %>
              </a>
            <% } %>

            <% if (pagination.hasNext) { %>
              <a href="?page=<%= pagination.currentPage + 1 %>&<%= paginationParams %>" class="pagination-btn">
                Next
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } else { %>
          <div style="text-align: center; padding: 40px; color: #6b7280;">
            <i class="fas fa-chart-line" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
            <p>No sales data found for the selected period.</p>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    // Quick filter buttons
    document.querySelectorAll('.quick-filter-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        // Remove active class from all buttons
        document.querySelectorAll('.quick-filter-btn').forEach(b => b.classList.remove('active'));
        
        // Add active class to clicked button
        this.classList.add('active');
        
        // Clear custom date inputs
        document.getElementById('startDate').value = '';
        document.getElementById('endDate').value = '';
        
        // Submit form with range parameter
        const form = document.getElementById('filterForm');
        const rangeInput = document.createElement('input');
        rangeInput.type = 'hidden';
        rangeInput.name = 'range';
        rangeInput.value = this.dataset.range;
        form.appendChild(rangeInput);
        form.submit();
      });
    });

    // Custom date inputs - remove active class from quick filters when used
    document.getElementById('startDate').addEventListener('change', function() {
      document.querySelectorAll('.quick-filter-btn').forEach(b => b.classList.remove('active'));
    });

    document.getElementById('endDate').addEventListener('change', function() {
      document.querySelectorAll('.quick-filter-btn').forEach(b => b.classList.remove('active'));
    });

    // Status filter - remove active class from quick filters when changed
    document.getElementById('statusSelect').addEventListener('change', function() {
      document.querySelectorAll('.quick-filter-btn').forEach(b => b.classList.remove('active'));
    });
  </script>
</body>
</html>