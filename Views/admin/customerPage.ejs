<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customers - Admin Dashboard</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #f5f6fa;
      color: #2c3e50;
    }

    .dashboard-container {
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar Styles */
    .sidebar {
      width: 250px;
      background-color: #ffffff;
      border-right: 1px solid #e5e7eb;
      padding: 20px 0;
      position: fixed;
      height: 100vh;
      overflow-y: auto;
    }

    .logo {
      padding: 0 20px 30px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 20px;
      font-weight: 700;
      color: #1a1a1a;
    }

    .logo i {
      font-size: 24px;
    }

    .nav-menu {
      list-style: none;
    }

    .nav-item {
      margin-bottom: 5px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: #6b7280;
      text-decoration: none;
      transition: all 0.3s ease;
      font-size: 14px;
    }

    .nav-link:hover {
      background-color: #f9fafb;
      color: #1a1a1a;
    }

    .nav-link.active {
      background-color: #f3f4f6;
      color: #1a1a1a;
      font-weight: 500;
      border-left: 3px solid #3b82f6;
    }

    .nav-link i {
      width: 20px;
      text-align: center;
      font-size: 16px;
    }

    /* Main Content */
    .main-content {
      margin-left: 250px;
      flex: 1;
      padding: 30px 40px;
    }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 30px;
      font-size: 14px;
      color: #6b7280;
    }

    .breadcrumb-separator {
      color: #d1d5db;
    }

    .breadcrumb-active {
      color: #1a1a1a;
      font-weight: 500;
    }

    /* Customers Card */
    .customers-card {
      background-color: #ffffff;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e5e7eb;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    .card-title {
      font-size: 18px;
      font-weight: 600;
      color: #1a1a1a;
    }

    .search-box {
      position: relative;
      width: 300px;
    }

    .search-input {
      width: 100%;
      padding: 10px 16px 10px 40px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: all 0.3s ease;
    }

    .search-input:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #9ca3af;
      font-size: 14px;
    }

    /* Table Styles */
    .customers-table {
      width: 100%;
      border-collapse: collapse;
    }

    .customers-table thead th {
      text-align: left;
      padding: 16px;
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid #e5e7eb;
      background-color: #f9fafb;
    }

    .customers-table tbody td {
      padding: 16px;
      font-size: 14px;
      color: #1a1a1a;
      border-bottom: 1px solid #f3f4f6;
    }

    .customers-table tbody tr {
      transition: background-color 0.2s ease;
    }

    .customers-table tbody tr:hover {
      background-color: #f9fafb;
    }

    .avatar {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 12px;
      color: white;
      text-transform: uppercase;
    }

    .avatar-eh { background-color: #7c3aed; }
    .avatar-ww { background-color: #2563eb; }
    .avatar-bs { background-color: #0891b2; }
    .avatar-rf { background-color: #db2777; }
    .avatar-dr { background-color: #dc2626; }
    .avatar-re { background-color: #ea580c; }
    .avatar-tw { background-color: #059669; }
    .avatar-am { background-color: #7c3aed; }

    .action-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      color: #6b7280;
      transition: all 0.2s ease;
      border-radius: 4px;
    }

    .action-btn:hover {
      background-color: #f3f4f6;
      color: #1a1a1a;
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
    }

    .pagination-btn {
      width: 36px;
      height: 36px;
      border: 1px solid #e5e7eb;
      background-color: white;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      color: #6b7280;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .pagination-btn:hover {
      background-color: #f9fafb;
      color: #1a1a1a;
    }

    .pagination-btn.active {
      background-color: #3b82f6;
      color: white;
      border-color: #3b82f6;
    }

    .pagination-dots {
      color: #9ca3af;
      padding: 0 8px;
    }

    /* Custom SweetAlert2 Styles */
    .swal2-popup {
      border-radius: 16px !important;
      padding: 40px 24px 24px !important;
    }

    .swal2-title {
      font-size: 16px !important;
      color: #9ca3af !important;
      font-weight: 400 !important;
      margin-bottom: 30px !important;
    }

    .swal2-html-container {
      margin: 0 !important;
    }

    .status-buttons {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 24px;
    }

    .status-btn {
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background-color: #1a1a1a;
      color: white;
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .status-btn:hover {
      background-color: #2d2d2d;
      transform: translateY(-2px);
    }

    .status-btn.block {
      background-color: #1a1a1a;
    }

    .status-btn.unblock {
      background-color: #1a1a1a;
    }

    .save-btn {
      width: 100%;
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background-color: #1a1a1a;
      color: white;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .save-btn:hover {
      background-color: #2d2d2d;
      transform: translateY(-2px);
    }

    .clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 6px;
  background-color: #dc2626;
  color: white;
  text-decoration: none;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 0.2s ease, transform 0.1s ease;
}

.clear-btn:hover {
  background-color: #b91c1c;
  transform: translateY(-1px);
}


    /* Responsive Design */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        z-index: 1000;
      }

      .main-content {
        margin-left: 0;
        padding: 20px;
      }

      .search-box {
        width: 100%;
      }

      .customers-table {
        font-size: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <%- include('partials/admin_sidebar') %>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <span>Admin</span>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-active">Dashboard</span>
      </div>

      <!-- Customers Card -->
      <div class="customers-card">
        <div class="card-header">
          <h2 class="card-title">Customers</h2>
         <form method="get" action="/admin/customers" class="search-box" style="display:flex; gap:8px; align-items:center;">
  <i class="fas fa-search search-icon"></i>

  <input 
    type="text" 
    class="search-input" 
    name="search"
    placeholder="Search customers"
    value="<%= search || '' %>"
  >

  <% if (search) { %>
    <a href="/admin/customers" class="clear-btn" title="Clear search">✕</a>
  <% } %>
</form>



        </div>

        <!-- Table -->
        <table class="customers-table">
          <thead>
  <tr>
    <th>Name</th>
    <th>Email</th>
    <th>Phone</th>
    <th>Status</th>
    <th style="width: 80px; text-align: center;">Action</th>
  </tr>
</thead>

       <tbody id="customersTableBody">
  <% if (!customers || customers.length === 0) { %>
    <tr>
      <td colspan="5" style="text-align:center; padding: 30px; color: #9ca3af; font-weight: 600;">
        NO USERS
      </td>
    </tr>
  <% } else { %>
    <% customers.forEach(user => { %>
      <tr>
        <td><%= user.username %></td>

        <td><%= user.email %></td>

        <td><%= user.phoneNumber || 'N/A' %></td>

        <td><%= user.is_blocked ? 'Blocked' : 'Active' %></td>

        <td style="text-align: center;">
          <button 
            class="action-btn"
            data-user-id="<%= user._id %>"
            data-status="<%= user.is_blocked ? 'blocked' : 'active' %>"
            data-username="<%= user.username %>"
            onclick="openStatusModalFromBtn(this)">
            <i class="fas fa-ellipsis-h"></i>
          </button>
        </td>
      </tr>
    <% }) %>
  <% } %>
</tbody>





        </table>

        <!-- Pagination -->
        <div class="pagination">
          <button class="pagination-btn">
            <i class="fas fa-chevron-left"></i>
          </button>
          <button class="pagination-btn active">1</button>
          <button class="pagination-btn">2</button>
          <span class="pagination-dots">...</span>
          <button class="pagination-btn">7</button>
          <button class="pagination-btn">8</button>
          <button class="pagination-btn">
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      </div>
    </main>
  </div>

  <script>
  let selectedStatus = 'block'
  let currentUserId = ''
  let currentUserName = ''

  function openStatusModalFromBtn(btn) {
    const userId = btn.dataset.userId
    const currentStatus = btn.dataset.status
    const username = btn.dataset.username

    currentUserId = userId
    currentUserName = username
    selectedStatus = currentStatus === 'blocked' ? 'unblock' : 'block'

    Swal.fire({
      title: 'Edit Customers Status',
      html: `
        <div class="status-buttons">
          <button class="status-btn block" onclick="selectStatus('block')" id="blockBtn">
            Block
          </button>
          <button class="status-btn unblock" onclick="selectStatus('unblock')" id="unblockBtn">
            Unblock
          </button>
        </div>
        <button class="save-btn" onclick="saveStatus()">
          SAVE CHANGE
        </button>
      `,
      showConfirmButton: false,
      showCloseButton: true,
      width: '480px',
      didOpen: () => updateButtonStates()
    })
  }

  function selectStatus(status) {
    selectedStatus = status
    updateButtonStates()
  }

  function updateButtonStates() {
    const blockBtn = document.getElementById('blockBtn')
    const unblockBtn = document.getElementById('unblockBtn')
    if (!blockBtn || !unblockBtn) return

    if (selectedStatus === 'block') {
      blockBtn.style.backgroundColor = '#3b82f6'
      unblockBtn.style.backgroundColor = '#1a1a1a'
    } else {
      blockBtn.style.backgroundColor = '#1a1a1a'
      unblockBtn.style.backgroundColor = '#3b82f6'
    }
  }

  function saveStatus() {
    Swal.close()

    fetch('/admin/customers/update-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId: currentUserId, status: selectedStatus })
    })
      .then(r => r.json())
      .then(data => {
        if (!data.success) throw new Error()
        Swal.fire({
          icon: 'success',
          title: 'Status Updated',
          text: `${currentUserName} has been ${selectedStatus}ed successfully!`,
          timer: 2000,
          showConfirmButton: false
        }).then(() => location.reload())
      })
      .catch(() => {
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: 'Failed to update customer status. Please try again.'
        })
      })
  }
</script>


</body>
</html>