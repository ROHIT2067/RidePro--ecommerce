<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customers - Admin Dashboard</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #f5f6fa;
      color: #2c3e50;
    }

    .dashboard-container {
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar Styles */
    .sidebar {
      width: 250px;
      background-color: #ffffff;
      border-right: 1px solid #e5e7eb;
      padding: 20px 0;
      position: fixed;
      height: 100vh;
      overflow-y: auto;
    }

    .logo {
      padding: 0 20px 30px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 20px;
      font-weight: 700;
      color: #1a1a1a;
    }

    .logo i {
      font-size: 24px;
    }

    .nav-menu {
      list-style: none;
    }

    .nav-item {
      margin-bottom: 5px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: #6b7280;
      text-decoration: none;
      transition: all 0.3s ease;
      font-size: 14px;
    }

    .nav-link:hover {
      background-color: #f9fafb;
      color: #1a1a1a;
    }

    .nav-link.active {
      background-color: #f3f4f6;
      color: #1a1a1a;
      font-weight: 500;
      border-left: 3px solid #3b82f6;
    }

    .nav-link i {
      width: 20px;
      text-align: center;
      font-size: 16px;
    }

    /* Main Content */
    .main-content {
      margin-left: 250px;
      flex: 1;
      padding: 30px 40px;
    }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 30px;
      font-size: 14px;
      color: #6b7280;
    }

    .breadcrumb-separator {
      color: #d1d5db;
    }

    .breadcrumb-active {
      color: #2c3e50;
      font-weight: 500;
    }

    /* Customers Card */
    .customers-card {
      background-color: #ffffff;
      border-radius: 12px;
      padding: 24px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    .card-title {
      font-size: 18px;
      font-weight: 600;
      color: #2c3e50;
    }

    .search-box {
      position: relative;
      width: 300px;
    }

    .search-input {
      width: 100%;
      padding: 10px 16px 10px 40px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: all 0.3s ease;
    }

    .search-input:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #9ca3af;
      font-size: 14px;
    }

    /* Table Styles */
    .customers-table {
      width: 100%;
      border-collapse: collapse;
    }

    .customers-table thead th {
      text-align: left;
      padding: 16px;
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid #e5e7eb;
      background-color: #f9fafb;
    }

    .customers-table tbody td {
      padding: 16px;
      font-size: 14px;
      color: #2c3e50;
      border-bottom: 1px solid #f3f4f6;
    }

    .customers-table tbody tr {
      transition: background-color 0.2s ease;
    }

    .customers-table tbody tr:hover {
      background-color: #f9fafb;
    }

    .avatar {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 12px;
      color: white;
      text-transform: uppercase;
    }

    .avatar-eh { background-color: #7c3aed; }
    .avatar-ww { background-color: #2563eb; }
    .avatar-bs { background-color: #0891b2; }
    .avatar-rf { background-color: #db2777; }
    .avatar-dr { background-color: #dc2626; }
    .avatar-re { background-color: #ea580c; }
    .avatar-tw { background-color: #059669; }
    .avatar-am { background-color: #7c3aed; }

    .action-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      color: #6b7280;
      transition: all 0.2s ease;
      border-radius: 4px;
    }

    .action-btn:hover {
      background-color: #f3f4f6;
      color: #2c3e50;
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
    }

    .pagination-btn {
      width: 36px;
      height: 36px;
      border: 1px solid #e5e7eb;
      background-color: white;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      color: #6b7280;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .pagination-btn:hover {
      background-color: #f9fafb;
      color: #2c3e50;
    }

    .pagination-btn.active {
      background-color: #3b82f6;
      color: white;
      border-color: #3b82f6;
    }

    .pagination-dots {
      color: #9ca3af;
      padding: 0 8px;
    }

    /* Custom SweetAlert2 Styles */
    .swal2-popup {
      border-radius: 16px !important;
      padding: 40px 24px 24px !important;
    }

    .swal2-title {
      font-size: 16px !important;
      color: #9ca3af !important;
      font-weight: 400 !important;
      margin-bottom: 30px !important;
    }

    .swal2-html-container {
      margin: 0 !important;
    }

    .status-buttons {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 24px;
    }

    .status-btn {
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background-color: #1a1a1a;
      color: white;
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .status-btn:hover {
      background-color: #2d2d2d;
      transform: translateY(-2px);
    }

    .status-btn.block {
      background-color: #1a1a1a;
    }

    .status-btn.unblock {
      background-color: #1a1a1a;
    }

    .save-btn {
      width: 100%;
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background-color: #1a1a1a;
      color: white;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .save-btn:hover {
      background-color: #2d2d2d;
      transform: translateY(-2px);
    }

    .clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 6px;
  background-color: #dc2626;
  color: white;
  text-decoration: none;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 0.2s ease, transform 0.1s ease;
}

.clear-btn:hover {
  background-color: #b91c1c;
  transform: translateY(-1px);
}

.switch {
  position: relative;
  display: inline-block;
  width: 46px;
  height: 24px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  inset: 0;
  background-color: #d1d5db;
  border-radius: 999px;
  transition: 0.2s;
}

.slider::before {
  content: "";
  position: absolute;
  height: 18px;
  width: 18px;
  left: 3px;
  top: 3px;
  background-color: white;
  border-radius: 50%;
  transition: 0.2s;
}

/* Active = Green */
.switch input:checked + .slider {
  background-color: #16a34a;
}

/* Blocked = Red */
.switch input:not(:checked) + .slider {
  background-color: #dc2626;
}

.switch input:checked + .slider::before {
  transform: translateX(22px);
}


    /* Responsive Design */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        z-index: 1000;
      }

      .main-content {
        margin-left: 0;
        padding: 20px;
      }

      .search-box {
        width: 100%;
      }

      .customers-table {
        font-size: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <%- include('partials/admin_sidebar') %>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <span>Admin</span>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-active">Dashboard</span>
      </div>

      <!-- Customers Card -->
      <div class="customers-card">
        <div class="card-header">
          <h2 class="card-title">Customers</h2>
         <form method="get" action="/admin/customers" class="search-box" style="display:flex; gap:8px; align-items:center;" novalidate>
  <i class="fas fa-search search-icon"></i>

  <input 
    type="text" 
    class="search-input" 
    name="search"
    placeholder="Search customers"
    value="<%= search || '' %>"
  >

  <% if (search) { %>
    <a href="/admin/customers" class="clear-btn" title="Clear search">✕</a>
  <% } %>
</form>



        </div>

        <!-- Table -->
        <table class="customers-table">
          <thead>
  <tr>
    <th>Name</th>
    <th>Email</th>
    <th>Phone</th>
    <th>Status</th>
    <th>Order Count</th>
    <th style="width: 80px; text-align: center;">Action</th>
  </tr>
</thead>

       <tbody id="customersTableBody">
  <% if (!customers || customers.length === 0) { %>
    <tr>
      <td colspan="5" style="text-align:center; padding: 30px; color: #9ca3af; font-weight: 600;">
        NO USERS
      </td>
    </tr>
  <% } else { %>
    <% customers.forEach(user => { %>
      <tr>
        <td><%= user.username %></td>

        <td><%= user.email %></td>

        <td><%= user.phoneNumber || 'N/A' %></td>

        <td><%= orderCount || "0" %></td>

        <td><%= user.is_blocked ? 'Blocked' : 'Active' %></td>

        <td style="text-align: center;">
          <label class="switch">
  <input 
    type="checkbox"
    <%= user.is_blocked ? '' : 'checked' %>
    data-user-id="<%= user._id %>"
    data-username="<%= user.username %>"
    onchange="confirmToggle(this)"
  >
  <span class="slider"></span>
</label>
        </td>
      </tr>
    <% }) %>
  <% } %>
</tbody>





        </table>

        <!-- Pagination -->
        <div class="pagination">

  <% if (currentPage > 1) { %>
    <a 
      class="pagination-btn" 
      href="/admin/customers?page=<%= currentPage - 1 %><%= search ? `&search=${search}` : '' %>">
      <i class="fas fa-chevron-left"></i>
    </a>
  <% } %>

  <% for (let i = 1; i <= totalPages; i++) { %>
    <a 
      class="pagination-btn <%= i === currentPage ? 'active' : '' %>" 
      href="/admin/customers?page=<%= i %><%= search ? `&search=${search}` : '' %>">
      <%= i %>
    </a>
  <% } %>

  <% if (currentPage < totalPages) { %>
    <a 
      class="pagination-btn" 
      href="/admin/customers?page=<%= currentPage + 1 %><%= search ? `&search=${search}` : '' %>">
      <i class="fas fa-chevron-right"></i>
    </a>
  <% } %>

</div>

      </div>
    </main>
  </div>

  <script>
  function confirmToggle(toggle) {
    const userId = toggle.dataset.userId
    const username = toggle.dataset.username
    const willBlock = !toggle.checked

    Swal.fire({
      icon: 'warning',
      title: willBlock ? 'Block user?' : 'Unblock user?',
      text: willBlock
        ? `Are you sure you want to block ${username}?`
        : `Are you sure you want to unblock ${username}?`,
      showCancelButton: true,
      confirmButtonText: willBlock ? 'Yes, Block' : 'Yes, Unblock',
      cancelButtonText: 'Cancel'
    }).then((result) => {
      if (!result.isConfirmed) {
        toggle.checked = !toggle.checked
        return
      }

      fetch('/admin/customers/update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId,
          status: willBlock ? 'block' : 'unblock'
        })
      })
        .then(r => r.json())
        .then(data => {
          if (!data.success) throw new Error()

          Swal.fire({
            icon: 'success',
            title: 'Updated',
            text: `${username} is now ${willBlock ? 'blocked' : 'active'}`,
            timer: 1400,
            showConfirmButton: false
          })
        })
        .catch(() => {
          toggle.checked = !toggle.checked
          Swal.fire({
            icon: 'error',
            title: 'Failed',
            text: 'Status update failed. Try again.'
          })
        })
    })
  }
</script>


</body>
</html>