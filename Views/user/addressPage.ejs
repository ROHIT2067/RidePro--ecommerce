<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shipping Address | RidePro</title>
  <link rel="stylesheet" href="/Styles/profile.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body>

<%- include('partials/header') %>

<main class="main-content">
  <div class="content-header">
    <div class="breadcrumb">
      <a href="/">RidePro</a> &gt; My Account &gt; Shipping Address
    </div>
    <h1>My Account</h1>
  </div>

  <div class="account-layout">
    <%- include('partials/sidebar') %>

    <div class="account-main">
      <h2>Shipping Address</h2>

      <!-- Address Selector Dropdown -->
      <div class="address-select">
        <form method="GET" action="/account/address">
          <select name="addressId" id="addressSelect">
            <option value="">Add</option>
            <% if (addresses && addresses.length) { %>
              <% addresses.forEach((addr, index) => { %>
                <option value="<%= addr._id %>" <%= selectedAddress && selectedAddress._id == addr._id ? 'selected' : '' %>>
                  Address <%= index + 1 %>
                </option>
              <% }) %>
            <% } %>
          </select>
        </form>
      </div>

      <% if (!addresses || addresses.length === 0) { %>
        <!-- No Address State -->
        <div class="no-address">
          <p>No address found.</p>
          <a href="/account/address/add" class="btn-primary">Add Address</a>
        </div>
      <% } else if (selectedAddress) { %>
        <!-- Address Display Card -->
        <div class="address-card">
          <div class="form-row">
            <label>Street Address</label>
            <input type="text" value="<%= selectedAddress.street %>" disabled />
          </div>

          <div class="form-row two">
            <div>
              <label>City</label>
              <input type="text" value="<%= selectedAddress.city %>" disabled />
            </div>
            <div>
              <label>State</label>
              <input type="text" value="<%= selectedAddress.state %>" disabled />
            </div>
          </div>

          <div class="form-row two">
            <div>
              <label>Zip Code</label>
              <input type="text" value="<%= selectedAddress.zip %>" disabled />
            </div>
            <div>
              <label>Country</label>
              <input type="text" value="<%= selectedAddress.country %>" disabled />
            </div>
          </div>

          <div class="form-row">
            <label>Mobile</label>
            <input type="text" value="<%= selectedAddress.mobile %>" disabled />
          </div>

          <div class="actions">
            <a href="/account/address/edit/<%= selectedAddress._id %>" class="btn-primary">Edit</a>
            <form method="POST" action="/account/address/delete/<%= selectedAddress._id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this address?');">
              <button type="submit" class="btn-danger">Delete Address</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer')%>

<script>
  // Handle address selection change
  document.getElementById('addressSelect')?.addEventListener('change', function() {
    if (this.value === '') {
      // Navigate to add address page
      window.location.href = '/account/address/add';
    } else {
      // Reload with selected address
      window.location.href = '/account/address?addressId=' + this.value;
    }
  });
</script>

</body>
</html>