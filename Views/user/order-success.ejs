<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Placed — RidePro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/footer.css" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0d0d0d; --surface: #141414; --surface2: #1c1c1c;
      --border: #2a2a2a; --text: #f0f0f0; --muted: #888;
      --accent: #e8411a; --success: #16a34a;
      --font: 'DM Sans', sans-serif; --display: 'Bebas Neue', sans-serif;
      --radius2: 14px;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; padding-top: 72px; }
    .page-wrap { max-width: 700px; margin: 0 auto; padding: 4rem 2rem 5rem; text-align: center; }
    .success-icon { width: 80px; height: 80px; background: rgba(22, 163, 74, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; }
    .success-icon i { font-size: 2.5rem; color: var(--success); }
    .success-title { font-family: var(--display); font-size: 2.8rem; letter-spacing: 0.04em; margin-bottom: 0.5rem; }
    .success-title em { color: var(--accent); font-style: normal; }
    .success-message { font-size: 1rem; color: var(--muted); margin-bottom: 2rem; line-height: 1.6; }
    .order-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); padding: 1.8rem 2rem; margin-bottom: 2rem; }
    .order-label { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem; }
    .order-id { font-family: var(--display); font-size: 1.8rem; letter-spacing: 0.04em; color: var(--accent); }
    .action-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.85rem 1.8rem; border-radius: 8px; font-size: 0.88rem; font-weight: 600; text-decoration: none; transition: background 0.15s, transform 0.15s; border: none; cursor: pointer; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #ff5733; transform: translateY(-1px); }
    .btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: var(--surface); }
    @media (max-width: 768px) {
      .page-wrap { padding: 5rem 1.25rem 3rem; }
      .success-title { font-size: 2.2rem; }
      .success-message { font-size: 0.92rem; }
      .order-box { padding: 1.5rem; }
      .order-id { font-size: 1.5rem; }
      .action-buttons { flex-direction: column; align-items: center; }
      .btn { width: 100%; justify-content: center; }
    }
</style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-wrap">
    <%- include('partials/breadcrumb', { breadcrumbs: [
      { name: 'Home', url: '/home' },
      { name: 'Checkout', url: '/checkout' },
      { name: 'Order Success' }
    ] }) %>
    <div class="success-icon">
      <i class="fa fa-check"></i>
    </div>
    <h1 class="success-title">Order Placed <em>Successfully!</em></h1>
    <p class="success-message">
      Thank you for your order. We've received your order and will process it shortly.<br>
      You will receive a confirmation email with order details.
    </p>

    <div class="order-box">
      <div class="order-label">Your Order ID</div>
      <div class="order-id"><%= orderId %></div>
    </div>

    <div class="action-buttons">
      <a href="/home" class="btn btn-primary">
        <i class="fa fa-home"></i> Continue Shopping
      </a>
      <a href="/account/orders" class="btn btn-secondary">
        <i class="fa fa-box"></i> View Orders
      </a>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
