<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Checkout — RidePro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/footer.css" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0d0d0d; --surface: #141414; --surface2: #1c1c1c; --surface3: #222;
      --border: #2a2a2a; --border2: #333; --text: #f0f0f0; --muted: #888; --muted2: #555;
      --accent: #e8411a; --accent2: #ff5733; --success: #16a34a; --danger: #ef4444;
      --font: 'DM Sans', sans-serif; --display: 'Bebas Neue', sans-serif;
      --radius: 10px; --radius2: 14px;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; padding-top: 72px; }
    .page-wrap { max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }
    .page-title { font-family: var(--display); font-size: 2.6rem; letter-spacing: 0.04em; margin-bottom: 0.4rem; }
    .page-title em { color: var(--accent); font-style: normal; }
    .page-subtitle { font-size: 0.84rem; color: var(--muted); margin-bottom: 2.5rem; }
    .checkout-layout { display: grid; grid-template-columns: 1fr 380px; gap: 2rem; align-items: start; }
    .section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); padding: 1.6rem 1.8rem; margin-bottom: 1.5rem; }
    .section-title { font-family: var(--display); font-size: 1.5rem; letter-spacing: 0.04em; margin-bottom: 1.2rem; }
    .address-list { display: flex; flex-direction: column; gap: 0.8rem; }
    .address-card { background: var(--surface2); border: 2px solid var(--border); border-radius: var(--radius); padding: 1rem 1.2rem; cursor: pointer; transition: border-color 0.2s; position: relative; }
    .address-card:hover { border-color: var(--border2); }
    .address-card.selected { border-color: var(--accent); background: rgba(232, 65, 26, 0.05); }
    .address-card input[type="radio"] { display: none; }
    .address-actions { position: absolute; top: 0.8rem; right: 0.8rem; display: flex; gap: 0.4rem; opacity: 0; transition: opacity 0.2s; }
    .address-card:hover .address-actions { opacity: 1; }
    .btn-edit-address { background: var(--surface3); border: 1px solid var(--border2); color: var(--muted); padding: 0.3rem 0.5rem; border-radius: 4px; font-size: 0.7rem; cursor: pointer; transition: all 0.15s; }
    .btn-edit-address:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
    .address-name { font-weight: 600; font-size: 0.92rem; margin-bottom: 0.3rem; }
    .address-details { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }
    .address-phone { font-size: 0.8rem; color: var(--muted); margin-top: 0.3rem; }
    .btn-add-address { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--surface3); color: var(--text); text-decoration: none; padding: 0.65rem 1.2rem; border-radius: 8px; font-size: 0.84rem; font-weight: 600; border: 1px solid var(--border2); transition: background 0.15s; margin-top: 0.5rem; cursor: pointer; }
    .btn-add-address:hover { background: var(--border2); }
    
    /* Address Form Modal */
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.7); z-index: 1000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.show { display: flex; }
    .address-modal { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); padding: 2rem; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .modal-title { font-family: var(--display); font-size: 1.4rem; letter-spacing: 0.04em; }
    .modal-close { background: none; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; padding: 0.25rem; }
    .modal-close:hover { color: var(--text); }
    .form-row { margin-bottom: 1rem; }
    .form-row.two { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-row label { display: block; font-size: 0.84rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text); }
    .form-row input { width: 100%; padding: 0.7rem 0.9rem; background: var(--surface2); border: 1px solid var(--border2); border-radius: 8px; font-family: var(--font); font-size: 0.84rem; color: var(--text); }
    .form-row input:focus { outline: none; border-color: var(--accent); }
    .form-row input.invalid { border-color: var(--danger); }
    .form-error { color: var(--danger); font-size: 0.76rem; margin-top: 0.3rem; display: none; }
    .modal-actions { display: flex; gap: 0.8rem; margin-top: 1.5rem; }
    .btn-save { flex: 1; padding: 0.8rem; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-family: var(--font); font-size: 0.84rem; font-weight: 600; cursor: pointer; }
    .btn-save:hover:not(:disabled) { background: var(--accent2); }
    .btn-save:disabled { background: var(--muted2); cursor: not-allowed; }
    .btn-cancel { flex: 1; padding: 0.8rem; background: var(--surface2); color: var(--text); border: 1px solid var(--border2); border-radius: 8px; font-family: var(--font); font-size: 0.84rem; font-weight: 600; cursor: pointer; }
    .btn-cancel:hover { background: var(--border2); }
    .order-item { display: grid; grid-template-columns: 60px 1fr auto; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .order-item:last-child { border-bottom: none; }
    .item-img { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; background: var(--surface2); }
    .item-info { display: flex; flex-direction: column; gap: 0.25rem; }
    .item-name { font-size: 0.88rem; font-weight: 600; }
    .item-variant { font-size: 0.76rem; color: var(--muted); }
    .item-price-qty { text-align: right; }
    .item-qty { font-size: 0.76rem; color: var(--muted); }
    .item-price { font-size: 0.92rem; font-weight: 600; margin-top: 0.2rem; }
    .order-summary { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); padding: 1.6rem 1.5rem; position: sticky; top: 72px; }
    .summary-title { font-family: var(--display); font-size: 1.4rem; letter-spacing: 0.04em; margin-bottom: 1.4rem; }
    .summary-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.86rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
    .summary-row:last-of-type { border-bottom: none; }
    .summary-row .label { color: var(--muted); }
    .summary-row .value { font-weight: 600; }
    .summary-row.total { padding-top: 1rem; }
    .summary-row.total .label { font-size: 0.95rem; font-weight: 600; color: var(--text); }
    .summary-row.total .value { font-size: 1.25rem; color: var(--accent); }
    .divider { height: 1px; background: var(--border); margin: 1rem 0; }
    .payment-method { background: var(--surface2); border: 1px solid var(--border2); border-radius: var(--radius); padding: 1rem 1.2rem; display: flex; align-items: center; gap: 0.8rem; transition: border-color 0.2s; }
    .payment-method:hover { border-color: var(--border); }
    .payment-method input[type="radio"]:checked + .payment-icon { color: var(--accent); }
    .payment-method input[type="radio"]:checked ~ .payment-info .payment-name { color: var(--accent); }
    .payment-option { margin-bottom: 0.8rem; }
    .payment-option:last-child { margin-bottom: 0; }
    .payment-icon { width: 40px; height: 40px; background: var(--surface3); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--accent); }
    .payment-info { flex: 1; }
    .payment-name { font-weight: 600; font-size: 0.88rem; }
    .payment-desc { font-size: 0.76rem; color: var(--muted); margin-top: 0.15rem; }
    .btn-place-order { width: 100%; padding: 0.9rem; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-family: var(--font); font-size: 0.92rem; font-weight: 600; cursor: pointer; margin-top: 1.2rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: background 0.15s, transform 0.15s; }
    .btn-place-order:hover:not(:disabled) { background: var(--accent2); transform: translateY(-1px); }
    .btn-place-order:disabled { background: var(--muted2); cursor: not-allowed; transform: none; }
    .secure-note { display: flex; align-items: center; justify-content: center; gap: 0.4rem; font-size: 0.72rem; color: var(--muted); margin-top: 0.85rem; }
    #toast { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; padding: 0.75rem 1.2rem; border-radius: 10px; font-size: 0.84rem; font-weight: 500; color: #fff; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35); opacity: 0; transform: translateY(8px); transition: opacity 0.28s, transform 0.28s; pointer-events: none; }
    @media (max-width: 900px) {
      .checkout-layout { grid-template-columns: 1fr; gap: 2.5rem; }
      .order-summary { position: static; order: 2; }
      .checkout-main { order: 1; }
    }
    @media (max-width: 600px) {
      body { padding-top: 60px; }
      .page-wrap { padding: 1.5rem 1rem 3rem; }
      .page-title { font-size: 2rem; }
      .section { padding: 1.25rem 1rem; }
      .form-row.two { grid-template-columns: 1fr; gap: 0; }
      .modal-actions { flex-direction: column-reverse; gap: 0.75rem; }
      .address-actions { opacity: 1; }
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-wrap">
    <%- include('partials/breadcrumb', { breadcrumbs: [
      { name: 'Home', url: '/home' },
      { name: 'Shopping Cart', url: '/cart' },
      { name: 'Checkout' }
    ] }) %>
    <h1 class="page-title">Checkout <em>—</em></h1>
    <p class="page-subtitle">Review your order and complete purchase</p>

    <!-- Success Message Display -->
    <% if (typeof addressSuccess !== 'undefined' && addressSuccess) { %>
      <div style="background: rgba(22, 163, 74, 0.1); border: 1px solid #16a34a; color: #16a34a; padding: 12px 16px; margin-bottom: 20px; border-radius: 8px; display: flex; align-items: center; gap: 8px;">
        <i class="fas fa-check-circle"></i>
        <%= addressSuccess %>
      </div>
    <% } %>

    <div class="checkout-layout">
      <div class="checkout-main">
        <!-- Delivery Address -->
        <div class="section">
          <h2 class="section-title">Delivery Address</h2>
          <p style="font-size: 0.82rem; color: var(--muted); margin-bottom: 1rem;">
            <i class="fa fa-info-circle"></i> To edit or manage your addresses, go to <a href="/account/address" style="color: var(--accent); text-decoration: none;">Account Settings</a>
          </p>
          <div class="address-list">
            <% addresses.forEach(address => { %>
              <label class="address-card <%= selectedAddress && selectedAddress._id.toString() === address._id.toString() ? 'selected' : '' %>">
                <input type="radio" name="address" value="<%= address._id %>" <%= selectedAddress && selectedAddress._id.toString() === address._id.toString() ? 'checked' : '' %>>
                <div class="address-actions">
                  <button class="btn-edit-address" onclick="editAddress(event, '<%= address._id %>', '<%= address.name %>', '<%= address.area %>', '<%= address.district %>', '<%= address.state %>', '<%= address.pincode %>', '<%= address.country %>', '<%= address.mobile %>')">
                    <i class="fa fa-edit"></i> Edit
                  </button>
                </div>
                <div class="address-name"><%= address.name %></div>
                <div class="address-details">
                  <%= address.area %>, <%= address.district %><br>
                  <%= address.state %>, <%= address.country %> - <%= address.pincode %>
                </div>
                <div class="address-phone"><i class="fa fa-phone"></i> <%= address.mobile %></div>
              </label>
            <% }) %>
          </div>
          <button class="btn-add-address" onclick="showAddressModal()">
            <i class="fa fa-plus"></i> Add New Address
          </button>
        </div>

        <!-- Order Items -->
        <div class="section">
          <h2 class="section-title">Order Items</h2>
          <% if (items && items.length > 0) { %>
            <% items.forEach(item => { 
              // Safety checks to prevent undefined errors
              if (!item || !item.variant_id || !item.variant_id.product_id) {
                return;
              }
              
              const variant = item.variant_id;
              const product = variant.product_id;
              const img = (variant.images && variant.images.length > 0) ? variant.images[0] : '/images/placeholder.jpg';
            %>
            <div class="order-item">
              <img src="<%= img %>" alt="<%= product.productName || 'Product' %>" class="item-img">
              <div class="item-info">
                <div class="item-name"><%= product.productName || 'Unknown Product' %></div>
                <div class="item-variant">
                  <% if (variant.size) { %><span>Size: <%= variant.size %></span><% } %>
                  <% if (variant.color) { %><span><%= variant.size ? ' • ' : '' %>Color: <%= variant.color %></span><% } %>
                </div>
              </div>
              <div class="item-price-qty">
                <div class="item-qty">Qty: <%= item.quantity || 0 %></div>
                <div class="item-price">₹<%= ((item.price || 0) * (item.quantity || 0)).toLocaleString('en-IN') %></div>
              </div>
            </div>
          <% }) %>
          <% } else { %>
            <div class="no-items">
              <p>No items found in your cart.</p>
              <a href="/home" class="btn btn-primary">Continue Shopping</a>
            </div>
          <% } %>
        </div>

        <!-- Payment Method -->
        <div class="section">
          <h2 class="section-title">Payment Method</h2>
          
          <!-- Wallet Payment Option -->
          <div class="payment-option" style="margin-bottom: 1rem;">
            <label class="payment-method" style="cursor: pointer; <%= walletBalance < finalTotal ? 'opacity: 0.6; cursor: not-allowed;' : '' %>">
              <input type="radio" name="paymentMethod" value="wallet" style="margin-right: 0.8rem;" <%= walletBalance < finalTotal ? 'disabled' : '' %>>
              <div class="payment-icon"><i class="fas fa-wallet"></i></div>
              <div class="payment-info">
                <div class="payment-name">Wallet</div>
                <div class="payment-desc">
                  Available Balance: ₹<%= walletBalance.toLocaleString('en-IN') %>
                  <% if (walletBalance < finalTotal) { %>
                    <span style="color: var(--danger); display: block; margin-top: 0.2rem;">
                      Insufficient balance (₹<%= (finalTotal - walletBalance).toLocaleString('en-IN') %> more needed)
                    </span>
                  <% } %>
                </div>
              </div>
            </label>
          </div>

          <!-- COD Payment Option -->
          <div class="payment-option">
            <label class="payment-method" style="cursor: pointer;">
              <input type="radio" name="paymentMethod" value="COD" style="margin-right: 0.8rem;" checked>
              <div class="payment-icon"><i class="fa fa-money-bill"></i></div>
              <div class="payment-info">
                <div class="payment-name">Cash on Delivery</div>
                <div class="payment-desc">Pay when you receive your order</div>
              </div>
            </label>
          </div>

          <!-- PayPal Payment Option -->
          <div class="payment-option">
            <label class="payment-method" style="cursor: pointer;">
              <input type="radio" name="paymentMethod" value="paypal" style="margin-right: 0.8rem;">
              <div class="payment-icon"><i class="fab fa-paypal"></i></div>
              <div class="payment-info">
                <div class="payment-name">PayPal</div>
                <div class="payment-desc">Pay securely with PayPal</div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="order-summary">
        <h3 class="summary-title">Order Summary</h3>
        <div class="summary-row">
          <span class="label">Subtotal</span>
          <span class="value">₹<%= subtotal.toLocaleString('en-IN') %></span>
        </div>
        <div class="summary-row">
          <span class="label">Shipping</span>
          <span class="value"><%= shippingCost === 0 ? 'FREE' : '₹' + shippingCost.toLocaleString('en-IN') %></span>
        </div>
        <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
        <div class="summary-row discount-row">
          <span class="label">Coupon Discount (<%= appliedCoupon.code %>)</span>
          <span class="value discount-amount" style="color: var(--success);">- ₹<%= appliedCoupon.discountAmount.toLocaleString('en-IN') %></span>
        </div>
        <div style="margin: 12px 0; padding: 10px 12px; background: rgba(255,193,7,0.1); border: 1px solid rgba(255,193,7,0.3); border-radius: 8px;">
          <div style="font-size: 12px; color: #d97706; line-height: 1.4;">
            <i class="fa fa-info-circle" style="margin-right: 4px;"></i>
            <strong>Important:</strong> Orders with coupon discounts do not allow individual item cancellation or returns. Only full order cancellation/return is available.
          </div>
        </div>
        <% } %>
        <div class="divider"></div>
        <div class="summary-row total">
          <span class="label">Total</span>
          <span class="value">₹<%= (typeof finalTotal !== 'undefined' ? finalTotal : totalAmount).toLocaleString('en-IN') %></span>
        </div>
        <button class="btn-place-order" onclick="placeOrder()">
          <i class="fa fa-check-circle"></i> Place Order
        </button>
        <div class="secure-note">
          <i class="fa fa-lock"></i> Secure Checkout
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <!-- Address Modal -->
  <div class="modal-overlay" id="addressModal">
    <div class="address-modal">
      <div class="modal-header">
        <h3 class="modal-title">Add New Address</h3>
        <button class="modal-close" onclick="hideAddressModal()">
          <i class="fa fa-times"></i>
        </button>
      </div>
      
      <form id="addressForm" novalidate>
        <input type="hidden" id="addressId" name="addressId" value="">
        
        <div class="form-row">
          <label for="name">Name *</label>
          <input type="text" id="name" name="name" required minlength="2" maxlength="50" />
          <span class="form-error" id="nameError">Please enter a valid name (2-50 characters)</span>
        </div>

        <div class="form-row">
          <label for="area">Area/Street *</label>
          <input type="text" id="area" name="area" required minlength="3" maxlength="100" />
          <span class="form-error" id="areaError">Please enter a valid area (3-100 characters)</span>
        </div>

        <div class="form-row two">
          <div>
            <label for="district">District *</label>
            <input type="text" id="district" name="district" required minlength="2" maxlength="50" />
            <span class="form-error" id="districtError">Please enter a valid district</span>
          </div>
          <div>
            <label for="state">State *</label>
            <input type="text" id="state" name="state" required minlength="2" maxlength="50" />
            <span class="form-error" id="stateError">Please enter a valid state</span>
          </div>
        </div>

        <div class="form-row two">
          <div>
            <label for="pincode">Pincode *</label>
            <input type="text" id="pincode" name="pincode" required pattern="\d{6}" maxlength="6" placeholder="123456" />
            <span class="form-error" id="pincodeError">Pincode must be exactly 6 digits</span>
          </div>
          <div>
            <label for="country">Country *</label>
            <input type="text" id="country" name="country" required minlength="2" maxlength="50" value="India" />
            <span class="form-error" id="countryError">Please enter a valid country</span>
          </div>
        </div>

        <div class="form-row">
          <label for="mobile">Mobile Number *</label>
          <input type="text" id="mobile" name="mobile" required pattern="\d{10}" maxlength="10" placeholder="9876543210" />
          <span class="form-error" id="mobileError">Mobile number must be exactly 10 digits</span>
        </div>

        <div class="modal-actions">
          <button type="submit" class="btn-save">Save Address</button>
          <button type="button" class="btn-cancel" onclick="hideAddressModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <div id="toast"></div>

  <script>
    // Check for error messages in URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');
    
    if (error) {
      let errorMessage = 'An error occurred';
      switch (error) {
        case 'payment_failed':
          errorMessage = 'PayPal payment failed. Please try again.';
          break;
        case 'payment_cancelled':
          errorMessage = 'PayPal payment was cancelled.';
          break;
        case 'payment_processing_failed':
          errorMessage = 'Payment processing failed. Please try again.';
          break;
      }
      showToast(errorMessage, 'error');
      
      // Clean URL by removing error parameter
      const newUrl = window.location.pathname;
      window.history.replaceState({}, document.title, newUrl);
    }

    // Address selection
    document.querySelectorAll('.address-card').forEach(card => {
      card.addEventListener('click', function() {
        document.querySelectorAll('.address-card').forEach(c => c.classList.remove('selected'));
        this.classList.add('selected');
        this.querySelector('input[type="radio"]').checked = true;
      });
    });

    // Address Modal Functions
    let isEditMode = false;

    function showAddressModal() {
      isEditMode = false;
      document.querySelector('.modal-title').textContent = 'Add New Address';
      document.querySelector('.btn-save').textContent = 'Save Address';
      document.getElementById('addressModal').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function editAddress(event, id, name, area, district, state, pincode, country, mobile) {
      event.stopPropagation(); // Prevent address card selection
      
      isEditMode = true;
      document.querySelector('.modal-title').textContent = 'Edit Address';
      document.querySelector('.btn-save').textContent = 'Update Address';
      
      // Populate form with existing data
      document.getElementById('addressId').value = id;
      document.getElementById('name').value = name;
      document.getElementById('area').value = area;
      document.getElementById('district').value = district;
      document.getElementById('state').value = state;
      document.getElementById('pincode').value = pincode;
      document.getElementById('country').value = country;
      document.getElementById('mobile').value = mobile;
      
      document.getElementById('addressModal').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function hideAddressModal() {
      document.getElementById('addressModal').classList.remove('show');
      document.body.style.overflow = '';
      // Reset form
      document.getElementById('addressForm').reset();
      document.querySelectorAll('.form-error').forEach(error => error.style.display = 'none');
      document.querySelectorAll('.invalid').forEach(input => input.classList.remove('invalid'));
      isEditMode = false;
    }

    // Close modal when clicking outside
    document.getElementById('addressModal').addEventListener('click', function(e) {
      if (e.target === this) {
        hideAddressModal();
      }
    });

    // Form validation patterns
    const patterns = {
      pincode: /^\d{6}$/,
      mobile: /^\d{10}$/,
      text: /^[a-zA-Z\s]{2,50}$/,
      area: /^.{3,100}$/
    };

    // Form inputs
    const inputs = {
      name: document.getElementById('name'),
      area: document.getElementById('area'),
      district: document.getElementById('district'),
      state: document.getElementById('state'),
      pincode: document.getElementById('pincode'),
      country: document.getElementById('country'),
      mobile: document.getElementById('mobile')
    };

    // Real-time validation
    inputs.pincode.addEventListener('input', function (e) {
      this.value = this.value.replace(/\D/g, '').slice(0, 6);
      validateField(this, patterns.pincode, 'pincodeError');
    });

    inputs.mobile.addEventListener('input', function (e) {
      this.value = this.value.replace(/\D/g, '').slice(0, 10);
      validateField(this, patterns.mobile, 'mobileError');
    });

    inputs.name.addEventListener('blur', function () {
      validateField(this, patterns.text, 'nameError');
    });

    inputs.district.addEventListener('blur', function () {
      validateField(this, patterns.text, 'districtError');
    });

    inputs.state.addEventListener('blur', function () {
      validateField(this, patterns.text, 'stateError');
    });

    inputs.area.addEventListener('blur', function () {
      validateField(this, patterns.area, 'areaError');
    });

    function validateField(input, pattern, errorId) {
      const errorElement = document.getElementById(errorId);
      if (input.value && !pattern.test(input.value)) {
        input.classList.add('invalid');
        errorElement.style.display = 'block';
        return false;
      } else {
        input.classList.remove('invalid');
        errorElement.style.display = 'none';
        return true;
      }
    }

    // Address form submission
    document.getElementById('addressForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Validate all fields
      let isValid = true;
      if (!validateField(inputs.name, patterns.text, 'nameError')) isValid = false;
      if (!validateField(inputs.area, patterns.area, 'areaError')) isValid = false;
      if (!validateField(inputs.district, patterns.text, 'districtError')) isValid = false;
      if (!validateField(inputs.state, patterns.text, 'stateError')) isValid = false;
      if (!validateField(inputs.pincode, patterns.pincode, 'pincodeError')) isValid = false;
      if (!validateField(inputs.mobile, patterns.mobile, 'mobileError')) isValid = false;

      if (!isValid) {
        showToast('Please fix the errors before submitting', 'error');
        return;
      }

      const saveBtn = document.querySelector('.btn-save');
      const originalText = saveBtn.textContent;
      saveBtn.disabled = true;
      saveBtn.textContent = isEditMode ? 'Updating...' : 'Saving...';

      try {
        const formData = new FormData(this);
        const addressData = Object.fromEntries(formData);
        
        const endpoint = isEditMode ? '/checkout/edit-address' : '/checkout/add-address';
        const method = 'POST';

        const response = await fetch(endpoint, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(addressData)
        });

        const data = await response.json();

        if (data.success) {
          showToast(isEditMode ? 'Address updated successfully!' : 'Address added successfully!', 'success');
          hideAddressModal();
          // Reload the page to show the updated address
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showToast(data.message || (isEditMode ? 'Failed to update address' : 'Failed to add address'), 'error');
        }
      } catch (error) {
        showToast('An error occurred. Please try again.', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });

    // Toast notification
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.style.background = type === 'success' ? '#16a34a' : '#ef4444';
      toast.style.opacity = '1';
      toast.style.transform = 'translateY(0)';
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(8px)';
      }, 3000);
    }

    // Place order
    async function placeOrder() {
      const selectedAddress = document.querySelector('input[name="address"]:checked');
      const selectedPayment = document.querySelector('input[name="paymentMethod"]:checked');
      
      if (!selectedAddress) {
        showToast('Please select a delivery address', 'error');
        return;
      }

      if (!selectedPayment) {
        showToast('Please select a payment method', 'error');
        return;
      }

      const btn = document.querySelector('.btn-place-order');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Processing...';

      try {
        const response = await fetch('/checkout/place-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            addressId: selectedAddress.value,
            paymentMethod: selectedPayment.value
          })
        });

        const data = await response.json();

        if (data.success) {
          // Handle PayPal payment
          if (selectedPayment.value === 'paypal' && data.paypalApprovalUrl) {
            // Redirect to PayPal for payment approval
            window.location.href = data.paypalApprovalUrl;
          } else {
            // Regular order success
            window.location.href = `/order-success?orderId=${data.orderId}`;
          }
        } else {
          // Check if there's a specific redirect URL for payment failures
          if (data.redirectUrl) {
            window.location.href = data.redirectUrl;
          } else {
            showToast(data.message || 'Failed to place order', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-check-circle"></i> Place Order';
          }
        }
      } catch (error) {
        showToast('An error occurred. Please try again.', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa fa-check-circle"></i> Place Order';
      }
    }
  </script>
</body>
</html>
