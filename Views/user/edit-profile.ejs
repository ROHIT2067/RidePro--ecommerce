  <body>
    <!-- Header -->
    <%- include('partials/header') %>

    <!-- Main Content -->
    <main class="main-content">
      <div class="content-header">
        <div class="breadcrumb">
          <a href="/">RidePro</a> &gt; My Account &gt; Edit Profile
        </div>
        <h1>My Account</h1>
      </div>

      <div class="account-layout">
        <!-- Sidebar -->
        <%- include('partials/sidebar') %>

        <!-- Edit Profile Form -->
        <div class="account-main">
          <div class="profile-header">
            <h2>Edit Profile</h2>
          </div>

          <form action="/account/edit" method="POST" class="edit-profile-form">
            <!-- Profile Picture Section -->
            <div class="profile-picture-section">
              <h3>Profile Picture</h3>
              <div class="picture-content">
                <div class="avatar-large-edit">
                  <%= typeof user !== 'undefined' && user.initials ?
                  user.initials : ':)' %>
                </div>
                <button type="button" class="btn-change-picture">
                  <i class="fa-solid fa-camera"></i> Change Picture
                </button>
              </div>
            </div>

            <!-- Personal Information Section -->
            <div class="personal-info-section">
              <h3>Personal Information</h3>

              <div class="form-group">
                <label for="fullName">User Name</label>
                <input
                  type="text"
                  id="fullName"
                  name="username"
                  value="<%= typeof user !== 'undefined' && user.username ? user.username : '' %>"
                  placeholder="Enter your New User Name"
                />
              </div>

              <div class="form-group email-group">
                <label for="email">Email Address</label>
                <div class="input-with-button">
                  <input
                    type="email"
                    id="email"
                    name="email"
                    value="<%= typeof user !== 'undefined' && user.email ? user.email : '' %>"
                    placeholder="Enter your New Email"
                    readonly
                  />
                  <button type="button" class="btn-change-email">
                    <i class="fa-solid fa-pen"></i> Change Email
                  </button>
                </div>
              </div>

              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  value="<%= typeof user !== 'undefined' && user.mobile ? user.mobile : '' %>"
                  placeholder="Enter your New Phone Number"
                />
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="button" class="btn-cancel-form">
                <i class="fa-solid fa-xmark"></i> Cancel
              </button>
              <button type="submit" class="btn-save-changes">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
              </button>
            </div>
          </form>

          <!-- Pagination -->
          <div class="pagination">
            <button type="button" class="pagination-btn" aria-label="Previous">
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>
            <button type="button" class="pagination-btn active">01</button>
            <button type="button" class="pagination-btn">02</button>
            <button type="button" class="pagination-btn">03</button>
            <button type="button" class="pagination-btn">04</button>
            <button type="button" class="pagination-btn">05</button>
            <button type="button" class="pagination-btn" aria-label="Next">
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </main>

