<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - RidePro</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/Styles/profile.css">
</head>

<body>
    <!-- Header -->
    <%- include('partials/header') %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <div class="breadcrumb">
                    <a href="/">RidePro</a> &gt; My Account &gt; Profile
                </div>
                <h1>My Account</h1>
            </div>

            <div class="account-layout">
                <!-- Sidebar -->
                <%- include('partials/sidebar') %>

                    <!-- Profile Display -->
                    <div class="account-main">
                        <div class="profile-header">
                            <h2>Profile Information</h2>
                            <a href="/account/edit" class="btn-edit">
                                <i class="fa-solid fa-pen-to-square"></i> Edit Profile
                            </a>
                        </div>

                        <div class="profile-content">
                            <!-- Profile Photo Section -->
                            <!-- Profile Photo Section -->
                            <div class="profile-photo-section">
                                <div class="avatar-large">
                                    <% if (user && user.avatar && user.avatar.url) { %>
                                        <img src="<%= user.avatar.url %>" alt="Profile Picture"
                                            style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                                        <% } else { %>
                                            <%= typeof user !=='undefined' && user.initials ? user.initials : ':)' %>
                                                <% } %>
                                </div>
                                <h3 class="profile-name">
                                    <%= typeof user !=='undefined' && user.username ? user.username : 'Guest User' %>
                                </h3>
                            </div>

                            <!-- Profile Details -->
                            <div class="profile-details">
                                <div class="detail-item">
                                    <div class="detail-label">
                                        <i class="fa-solid fa-user"></i>
                                        User Name
                                    </div>
                                    <div class="detail-value">
                                        <%= typeof user !=='undefined' && user.username ? user.username : 'Not provided'
                                            %>
                                    </div>
                                </div>

                                <div class="detail-item">
                                    <div class="detail-label">
                                        <i class="fa-solid fa-envelope"></i>
                                        Email Address
                                    </div>
                                    <div class="detail-value">
                                        <%= typeof user !=='undefined' && user.email ? user.email : 'Not provided' %>
                                    </div>
                                </div>

                                <div class="detail-item">
                                    <div class="detail-label">
                                        <i class="fa-solid fa-phone"></i>
                                        Mobile Number
                                    </div>
                                    <div class="detail-value">
                                        <%= typeof user !=='undefined' && user.mobile ? user.mobile : 'Not provided' %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pagination -->
                        <div class="pagination">
                            <button type="button" class="pagination-btn" aria-label="Previous">
                                <svg fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
                                        clip-rule="evenodd" />
                                </svg>
                            </button>
                            <button type="button" class="pagination-btn active">01</button>
                            <button type="button" class="pagination-btn">02</button>
                            <button type="button" class="pagination-btn">03</button>
                            <button type="button" class="pagination-btn">04</button>
                            <button type="button" class="pagination-btn">05</button>
                            <button type="button" class="pagination-btn" aria-label="Next">
                                <svg fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                        clip-rule="evenodd" />
                                </svg>
                            </button>
                        </div>
                    </div>
            </div>
        </main>

        <!-- Footer -->
        <%- include('partials/footer') %>

</body>

</html>