<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Details - RidePro</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/Styles/profile.css">
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-left">Account Details</div>
        <a href="/" class="logo">
            <div class="logo-circle">R</div>
        </a>
        <div class="nav-right">
  <a class="nav-item">
    <i class="fa-solid fa-magnifying-glass nav-icon"></i> Search
  </a>

  <a href="/login" class="nav-item">
    <i class="fa-solid fa-user nav-icon"></i>
    <span><%= currentUser ? currentUser.username : "Guest" %></span>
  </a>

  <a class="nav-item">
    <i class="fa-solid fa-cart-shopping nav-icon"></i>
  </a>
</div>

    </header>

    <!-- Main Content -->
    <main class="main-content">
        <div class="content-header">
            <div class="breadcrumb">
                <a href="/">RidePro</a> &gt; My Account
            </div>
            <h1>My Account</h1>
        </div>

        <div class="account-layout">
            <!-- Sidebar -->
             <%- include('partials/sidebar') %>


            <!-- Account Details form -->
            <div class="account-main">
                <h2>Account Details</h2>

                <form class="account-details-form" action="/account/details" method="POST">
                    <div class="avatar-block">
                        <div class="avatar">
                            <%= typeof user !== 'undefined' && user.initials ? user.initials : 'AN' %>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="fullname">Full name</label>
                        <input type="text" id="fullname" name="fullName" value="<%= typeof user !== 'undefined' && user.fullName ? user.fullName : '' %>" placeholder="Enter your full name">
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" value="<%= typeof user !== 'undefined' && user.email ? user.email : '' %>" placeholder="Enter your email">
                    </div>

                    <div class="form-group">
                        <label for="mobile">Mobile</label>
                        <input type="tel" id="mobile" name="mobile" value="<%= typeof user !== 'undefined' && user.mobile ? user.mobile : '' %>" placeholder="Enter your mobile number">
                    </div>

                    <button type="submit" class="btn-save">Save Changes</button>
                </form>

                <!-- Pagination -->
                <div class="pagination">
                    <button type="button" class="pagination-btn" aria-label="Previous">
                        <svg fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </button>
                    <button type="button" class="pagination-btn active">01</button>
                    <button type="button" class="pagination-btn">02</button>
                    <button type="button" class="pagination-btn">03</button>
                    <button type="button" class="pagination-btn">04</button>
                    <button type="button" class="pagination-btn">05</button>
                    <button type="button" class="pagination-btn" aria-label="Next">
                        <svg fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-graphic"></div>
        <div class="footer-content">
            <div class="footer-section">
                <h3>STORE</h3>
                <ul>
                    <li><a href="#">Protective Gear</a></li>
                    <li><a href="#">Performance Layers</a></li>
                    <li><a href="#">Luggage</a></li>
                    <li><a href="#">Accessories</a></li>
                    <li><a href="#">Lifestyle Merch</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>SUPPORT</h3>
                <ul>
                    <li><a href="#">Shipping Policy</a></li>
                    <li><a href="#">Warranty</a></li>
                    <li><a href="#">Refund / Exchange Policy</a></li>
                    <li><a href="#">Care Instructions</a></li>
                    <li><a href="#">Wingman Insurance</a></li>
                    <li><a href="/terms">Terms Of Service</a></li>
                    <li><a href="/privacy">Privacy Policy</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>CONTACT US</h3>
                <p>Contact Number: 07795688316</p>
                <p>Mon-Fri 11:00 AM to 4:30 PM</p>
                <p>For any Queries please contact <a href="#">Customer Support</a></p>
            </div>

            <div class="footer-section">
                <h3>CAREERS</h3>
                <p><a href="#">Join #TeamRYNCX</a></p>
            </div>

            <div class="footer-section">
                <h3>LOCATION</h3>
                <p>Rync Gear HQ,<br>1107, Kohinoor Square,<br>NC Kelkar Marg,<br>Opposite Shiv Sena Bhavan,<br>Dadar (West),<br>Mumbai, Maharashtra 400020</p>
                <p>+91 7795688314</p>
            </div>
        </div>

        <div class="footer-bottom">
            <div></div>
            <div class="social-icons">
                <a href="#" aria-label="Twitter">
                    <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                </a>
                <a href="#" aria-label="Facebook">
                    <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                </a>
                <a href="#" aria-label="Instagram">
                    <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                </a>
                <a href="#" aria-label="YouTube">
                    <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                </a>
            </div>
        </div>
    </footer>
</body>
</html>
