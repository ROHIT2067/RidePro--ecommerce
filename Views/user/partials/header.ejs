<!-- ===== FIXED HEADER ===== -->
<header class="site-header" id="site-header">

  <!-- Left: Search Button -->
  <button type="button" class="search-btn" id="searchToggle" aria-label="Open search">
    <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd"
        d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
        clip-rule="evenodd" />
    </svg>
    <span class="search-btn-label">Search</span>
  </button>

  <!-- Center: Logo -->
  <a href="/home" class="site-logo" aria-label="RidePro Home">RidePro</a>

  <!-- Right: Cart + Account -->
  <nav class="header-nav" aria-label="Main Navigation">
    <a href="/cart" class="nav-item" aria-label="Cart">
      <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
        <path
          d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zm14 15.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
      </svg>
      <span class="nav-label">Cart</span>
    </a>
    <a href="<%= typeof currentUser !== 'undefined' && currentUser ? '/account' : '/login' %>" class="nav-item" aria-label="Account">
      <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
      </svg>
      <span class="nav-label">
        <%= typeof currentUser !== 'undefined' && currentUser ? currentUser.username : 'Login' %>
      </span>
    </a>
  </nav>

</header>

<!-- Search Overlay -->
<div class="search-overlay" id="searchOverlay" role="dialog" aria-label="Search" aria-hidden="true">
  <button class="search-close" id="searchClose" aria-label="Close search">&#x2715;</button>
  <form class="search-form" action="/search" method="GET">
    <input
      type="text"
      name="q"
      class="search-input"
      placeholder="Search products…"
      autocomplete="off"
      aria-label="Search products"
    />
    <button type="submit" class="search-submit" aria-label="Submit search">
      <svg fill="currentColor" viewBox="0 0 20 20" width="22" height="22">
        <path fill-rule="evenodd"
          d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
          clip-rule="evenodd" />
      </svg>
    </button>
  </form>
</div>

<!-- Spacer pushes page content below the fixed bar -->
<div class="header-spacer"></div>

<!-- Header JS — guarded so it's safe even if partial is included multiple times -->
<script>
  (function () {
    if (window.__headerInitDone) return;
    window.__headerInitDone = true;

    var overlay = document.getElementById('searchOverlay');
    var input   = overlay ? overlay.querySelector('.search-input') : null;

    function openSearch() {
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      if (input) input.focus();
    }

    function closeSearch() {
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    var toggleBtn = document.getElementById('searchToggle');
    var closeBtn  = document.getElementById('searchClose');

    if (toggleBtn) toggleBtn.addEventListener('click', openSearch);
    if (closeBtn)  closeBtn.addEventListener('click', closeSearch);

    if (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeSearch();
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay && overlay.classList.contains('open')) {
        closeSearch();
      }
    });
  })();
</script>