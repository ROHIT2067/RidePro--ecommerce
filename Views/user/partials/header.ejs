<!-- ===== FIXED HEADER ===== -->
<header class="site-header" id="site-header">

  <!-- Left: Search Button -->
  <div></div>
<div class="header-spacer"></div>
  <!-- Center: Logo -->
  <a href="/home" class="site-logo" aria-label="RidePro Home">RidePro</a>

  <!-- Right: Wishlist + Cart + Account -->
  <nav class="header-nav" aria-label="Main Navigation">

    <a href="/wishlist" class="nav-item wishlist-link" aria-label="Wishlist">
      <div class="wishlist-icon-wrap">
        <svg class="nav-icon" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 20 20">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
        </svg>
        <% if (typeof wishlistCount !== 'undefined' && wishlistCount > 0) { %>
          <span class="wishlist-badge"><%= wishlistCount > 99 ? '99+' : wishlistCount %></span>
        <% } %>
      </div>
      <span class="nav-label">Wishlist</span>
    </a>

    <a href="/cart" class="nav-item cart-link" aria-label="Cart">
      <div class="cart-icon-wrap">
        <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
          <path
            d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zm14 15.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
        </svg>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="cart-badge"><%= cartCount > 99 ? '99+' : cartCount %></span>
        <% } %>
      </div>
      <span class="nav-label">Cart</span>
    </a>

    <a href="<%= typeof currentUser !== 'undefined' && currentUser ? '/account' : '/login' %>" class="nav-item" aria-label="Account">
      <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
      </svg>
      <span class="nav-label">
        <%= typeof currentUser !== 'undefined' && currentUser ? currentUser.username : 'Login' %>
      </span>
    </a>

  </nav>

</header>

<!-- Block Check Handler - Detects blocked users on API calls -->
<script src="/blockCheckHandler.js"></script>