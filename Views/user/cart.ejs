<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Cart — RidePro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/footer.css" />
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0d0d0d;
      --surface: #141414;
      --surface2: #1c1c1c;
      --surface3: #222;
      --border: #2a2a2a;
      --border2: #333;
      --text: #f0f0f0;
      --muted: #888;
      --muted2: #555;
      --accent: #e8411a;
      --accent2: #ff5733;
      --success: #16a34a;
      --danger: #ef4444;
      --font: 'DM Sans', sans-serif;
      --display: 'Bebas Neue', sans-serif;
      --radius: 10px;
      --radius2: 14px;
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .page-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 2rem 5rem;
    }

    .page-title {
      font-family: var(--display);
      font-size: 2.6rem;
      letter-spacing: 0.04em;
      margin-bottom: 0.4rem;
    }

    .page-title em {
      color: var(--accent);
      font-style: normal;
    }

    .page-subtitle {
      font-size: 0.84rem;
      color: var(--muted);
      margin-bottom: 2.5rem;
    }

    .cart-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 2rem;
      align-items: start;
    }

    .cart-items {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .cart-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 1.2rem 1.4rem;
      display: grid;
      grid-template-columns: 88px 1fr auto;
      gap: 1.2rem;
      align-items: center;
      transition: border-color 0.2s;
    }

    .cart-item:hover {
      border-color: var(--border2);
    }

    .cart-item.oos {
      opacity: 0.6;
      border-color: rgba(239, 68, 68, 0.35);
    }

    .item-img-wrap {
      width: 88px;
      height: 88px;
      border-radius: 8px;
      background: var(--surface2);
      border: 1px solid var(--border);
      overflow: hidden;
      flex-shrink: 0;
    }

    .item-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .item-img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      color: var(--muted2);
    }

    .item-info {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      min-width: 0;
    }

    .item-name {
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .item-name a {
      color: var(--text);
      text-decoration: none;
    }

    .item-name a:hover {
      color: var(--accent);
    }

    .item-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .item-tag {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.18rem 0.55rem;
      border-radius: 4px;
      background: var(--surface3);
      color: var(--muted);
      border: 1px solid var(--border2);
    }

    .item-price {
      font-size: 1rem;
      font-weight: 700;
    }

    .item-unit-price {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .stock-warn {
      font-size: 0.72rem;
      color: #fbbf24;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .oos-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.28);
      color: #f87171;
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.22rem 0.65rem;
      border-radius: 20px;
      margin-top: 0.2rem;
    }

    .item-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.75rem;
    }

    .qty-ctrl {
      display: flex;
      align-items: center;
      border: 1px solid var(--border2);
      border-radius: 8px;
      overflow: hidden;
    }

    .qty-btn {
      width: 34px;
      height: 34px;
      background: var(--surface2);
      border: none;
      color: var(--text);
      font-size: 0.85rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s;
    }

    .qty-btn:hover:not(:disabled) {
      background: var(--surface3);
    }

    .qty-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .qty-val {
      width: 42px;
      height: 34px;
      background: var(--surface);
      border: none;
      border-left: 1px solid var(--border2);
      border-right: 1px solid var(--border2);
      font-family: var(--font);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--text);
      text-align: center;
      outline: none;
    }

    .btn-remove {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 0.75rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.25rem 0.5rem;
      border-radius: 5px;
      transition: color 0.15s, background 0.15s;
    }

    .btn-remove:hover {
      color: var(--danger);
      background: rgba(239, 68, 68, 0.08);
    }

    .empty-cart {
      text-align: center;
      padding: 5rem 2rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
    }

    .empty-cart i {
      font-size: 3rem;
      color: var(--muted2);
      margin-bottom: 1rem;
      display: block;
    }

    .empty-cart h3 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .empty-cart p {
      font-size: 0.84rem;
      color: var(--muted);
      margin-bottom: 1.8rem;
    }

    .btn-shop {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      padding: 0.75rem 1.8rem;
      border-radius: 8px;
      font-size: 0.88rem;
      font-weight: 600;
      transition: background 0.15s, transform 0.15s;
    }

    .btn-shop:hover {
      background: var(--accent2);
      transform: translateY(-1px);
    }

    .order-summary {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 1.6rem 1.5rem;
      position: sticky;
      top: 1.5rem;
    }

    .summary-title {
      font-family: var(--display);
      font-size: 1.4rem;
      letter-spacing: 0.04em;
      margin-bottom: 1.4rem;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.86rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border);
    }

    .summary-row:last-of-type {
      border-bottom: none;
    }

    .summary-row .label {
      color: var(--muted);
    }

    .summary-row .value {
      font-weight: 600;
    }

    .summary-row.total {
      padding-top: 1rem;
    }

    .summary-row.total .label {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
    }

    .summary-row.total .value {
      font-size: 1.25rem;
      color: var(--accent);
    }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 1rem 0;
    }

    .coupon-wrap {
      margin-bottom: 1.2rem;
    }

    .coupon-label {
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .coupon-input-row {
      display: flex;
      gap: 0.5rem;
    }

    .coupon-input {
      flex: 1;
      padding: 0.6rem 0.9rem;
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 7px;
      color: var(--text);
      font-family: var(--font);
      font-size: 0.84rem;
      outline: none;
      transition: border-color 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .coupon-input:focus {
      border-color: var(--accent);
    }

    .coupon-apply {
      padding: 0.6rem 1rem;
      background: var(--surface3);
      color: var(--text);
      border: 1px solid var(--border2);
      border-radius: 7px;
      font-family: var(--font);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }

    .coupon-apply:hover {
      background: var(--border2);
    }

    .coupon-msg {
      font-size: 0.75rem;
      margin-top: 0.4rem;
    }

    .coupon-msg.success {
      color: #4ade80;
    }

    .coupon-msg.error {
      color: #f87171;
    }

    .btn-checkout {
      width: 100%;
      padding: 0.9rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font);
      font-size: 0.92rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: background 0.15s, transform 0.15s;
    }

    .btn-checkout:hover:not(:disabled) {
      background: var(--accent2);
      transform: translateY(-1px);
    }

    .btn-checkout:disabled {
      background: var(--muted2);
      cursor: not-allowed;
      transform: none;
    }

    .oos-checkout-note {
      font-size: 0.75rem;
      color: #f87171;
      text-align: center;
      margin-top: 0.6rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
    }

    .secure-note {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.85rem;
    }

    #toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      padding: 0.75rem 1.2rem;
      border-radius: 10px;
      font-size: 0.84rem;
      font-weight: 500;
      color: #fff;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.28s, transform 0.28s;
      pointer-events: none;
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.75);
      z-index: 10000;
      display: none;
      align-items: center;
      justify-content: center;
      animation: fadeIn 0.2s ease;
    }

    .modal-overlay.show {
      display: flex;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    .modal-box {
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: var(--radius2);
      padding: 1.8rem 2rem;
      max-width: 420px;
      width: 90%;
      animation: slideUp 0.25s ease;
    }

    @keyframes slideUp {
      from {
        transform: translateY(20px);
        opacity: 0;
      }

      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .modal-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid rgba(239, 68, 68, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.2rem;
      font-size: 1.5rem;
      color: var(--danger);
    }

    .modal-title {
      font-size: 1.3rem;
      font-weight: 600;
      text-align: center;
      margin-bottom: 0.6rem;
    }

    .modal-text {
      font-size: 0.88rem;
      color: var(--muted);
      text-align: center;
      line-height: 1.5;
      margin-bottom: 1.8rem;
    }

    .modal-actions {
      display: flex;
      gap: 0.7rem;
    }

    .modal-btn {
      flex: 1;
      padding: 0.75rem 1.2rem;
      border: none;
      border-radius: 8px;
      font-family: var(--font);
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
    }

    .modal-btn-cancel {
      background: var(--surface2);
      color: var(--text);
      border: 1px solid var(--border2);
    }

    .modal-btn-cancel:hover {
      background: var(--surface3);
    }

    .modal-btn-confirm {
      background: var(--danger);
      color: #fff;
    }

    .modal-btn-confirm:hover {
      background: #dc2626;
    }

    @media (max-width: 900px) {
      .cart-layout {
        grid-template-columns: 1fr;
      }

      .order-summary {
        position: static;
      }
    }

    @media (max-width: 560px) {
      .cart-item {
        grid-template-columns: 72px 1fr;
      }

      .item-actions {
        flex-direction: row;
        align-items: center;
        grid-column: 1 / -1;
        justify-content: space-between;
      }

      .page-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 5rem 2rem 5rem;
      }

      .modal-box {
        padding: 1.5rem 1.5rem;
      }

      .modal-actions {
        flex-direction: column-reverse;
      }
    }
  </style>
</head>

<body>

  <%- include('partials/header') %>

    <div class="page-wrap">
      <%- include('partials/breadcrumb', { breadcrumbs: [
        { name: 'Home', url: '/home' },
        { name: 'Shopping Cart' }
      ] }) %>
      <h1 class="page-title">Your <em>Cart</em></h1>
      <p class="page-subtitle">
        <%= cartCount %> item<%= cartCount !==1 ? 's' : '' %> in your cart
      </p>

      <%# Removed/unlisted items notice %>
        <% if (typeof unavailableItems !=='undefined' && unavailableItems.length> 0) { %>
          <div
            style="background: rgba(239,68,68,0.07); border: 1px solid rgba(239,68,68,0.22); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; display: flex; gap: 0.75rem; align-items: flex-start; font-size: 0.84rem; color: #f87171;">
            <i class="fa fa-circle-exclamation" style="margin-top:0.15rem; flex-shrink:0;"></i>
            <div>
              <strong style="display:block; margin-bottom:0.3rem;">Some items were removed from your cart</strong>
              <ul style="margin-top:0.4rem; padding-left:1.2rem; display:flex; flex-direction:column; gap:0.2rem;">
                <% unavailableItems.forEach(function(item) { %>
                  <li>
                    <%= item.productName %> — <span style="opacity:0.8;">
                        <%= item.reason %>
                      </span>
                  </li>
                  <% }); %>
              </ul>
            </div>
          </div>
          <% } %>

            <% if (typeof adjustmentWarnings !=='undefined' && adjustmentWarnings.length> 0) { %>
              <div
                style="background: rgba(251,191,36,0.07); border: 1px solid rgba(251,191,36,0.22); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; display: flex; gap: 0.75rem; align-items: flex-start; font-size: 0.84rem; color: #fbbf24;">
                <i class="fa fa-triangle-exclamation" style="margin-top:0.15rem; flex-shrink:0;"></i>
                <div>
                  <strong style="display:block; margin-bottom:0.3rem;">Stock adjustments</strong>
                  <ul style="margin-top:0.4rem; padding-left:1.2rem; display:flex; flex-direction:column; gap:0.2rem;">
                    <% adjustmentWarnings.forEach(function(warn) { %>
                      <li>
                        <%= warn.productName %> — <span style="opacity:0.8;">
                            <%= warn.reason %>
                          </span>
                      </li>
                      <% }); %>
                  </ul>
                </div>
              </div>
              <% } %>

                <% if (typeof checkoutError !=='undefined' && checkoutError) { %>
                  <div
                    style="background: rgba(239,68,68,0.07); border: 1px solid rgba(239,68,68,0.22); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; display: flex; gap: 0.75rem; align-items: flex-start; font-size: 0.84rem; color: #f87171;">
                    <i class="fa fa-circle-exclamation" style="margin-top:0.15rem; flex-shrink:0;"></i>
                    <div>
                      <strong style="display:block; margin-bottom:0.3rem;">Checkout Error</strong>
                      <p style="margin:0;">
                        <%= checkoutError %>
                      </p>
                    </div>
                  </div>
                  <% } %>

                    <% if (items.length===0) { %>
                      <div class="empty-cart">
                        <i class="fa fa-cart-shopping"></i>
                        <h3>Your cart is empty</h3>
                        <p>Looks like you haven't added anything yet. Browse our collection and find something you love.
                        </p>
                        <a href="/products" class="btn-shop"><i class="fa fa-arrow-left"></i> Continue Shopping</a>
                      </div>
                      <% } else { %>
                        <div class="cart-layout">
                          <div class="cart-items" id="cartItems">
                            <% items.forEach(function(item) { const variant=item.variant_id; const
                              product=variant.product_id; const firstImg=variant.images && variant.images.length ?
                              variant.images[0] : null; const stock=variant.stock_quantity; const itemTotal=item.price *
                              item.quantity; const isUnavailable=item.isOutOfStock; %>
                              <div class="cart-item <%= isUnavailable ? 'oos' : '' %>" id="item-<%= variant._id %>">
                                <div class="item-img-wrap">
                                  <% if (firstImg) { %>
                                    <img class="item-img" src="<%= firstImg %>" alt="<%= product.productName %>" />
                                    <% } else { %>
                                      <div class="item-img-placeholder"><i class="fa fa-image"></i></div>
                                      <% } %>
                                </div>

                                <div class="item-info">
                                  <div class="item-name">
                                    <a href="/product/<%= product._id %>">
                                      <%= product.productName %>
                                    </a>
                                  </div>
                                  <div class="item-meta">
                                    <% if (variant.size) { %><span class="item-tag">
                                        <%= variant.size %>
                                      </span>
                                      <% } %>
                                        <% if (variant.color) { %><span class="item-tag">
                                            <%= variant.color %>
                                          </span>
                                          <% } %>
                                  </div>
                                  <% if (isUnavailable) { %>
                                    <div class="oos-badge"><i class="fa fa-ban"></i> Out of Stock</div>
                                    <% } else { %>
                                      <div class="item-price" id="total-<%= variant._id %>">₹<%=
                                          itemTotal.toLocaleString('en-IN') %>
                                      </div>
                                      <% if (item.originalPrice && item.finalPrice < item.originalPrice) { %>
                                        <div class="item-unit-price">
                                          ₹<%= item.finalPrice.toLocaleString('en-IN') %> each 
                                          <span style="text-decoration: line-through; color: #f87171; margin-left: 0.5rem;">₹<%= item.originalPrice.toLocaleString('en-IN') %></span>
                                        </div>
                                      <% } else { %>
                                        <div class="item-unit-price">₹<%= item.price.toLocaleString('en-IN') %> each</div>
                                      <% } %>
                                      <% if (stock> 0 && stock <= 5) { %>
                                          <div class="stock-warn"><i class="fa fa-circle-exclamation"></i> Only <%=
                                              stock %>
                                              left</div>
                                          <% } %>
                                            <% } %>
                                </div>

                                <div class="item-actions">
                                  <% if (!isUnavailable) { %>
                                    <div class="qty-ctrl">
                                      <button class="qty-btn"
                                        onclick="updateQty('<%= variant._id %>', <%= item.quantity - 1 %>)"
                                        <%=item.quantity <=1 ? 'disabled' : '' %>>
                                        <i class="fa fa-minus"></i>
                                      </button>
                                      <input class="qty-val" type="text" value="<%= item.quantity %>"
                                        id="qty-<%= variant._id %>" readonly />
                                      <button class="qty-btn"
                                        onclick="updateQty('<%= variant._id %>', <%= item.quantity + 1 %>)"
                                        <%=(item.quantity>= 5 || item.quantity >= stock) ? 'disabled' : '' %>>
                                        <i class="fa fa-plus"></i>
                                      </button>
                                    </div>
                                    <% } %>
                                      <button class="btn-remove" onclick="removeItem('<%= variant._id %>')">
                                        <i class="fa fa-trash-can"></i> Remove
                                      </button>
                                </div>
                              </div>
                              <% }); %>

                                <div style="margin-top: 1rem; display: flex; justify-content: flex-end;">
                                  <button class="btn-remove" onclick="clearCart()" style="color: var(--danger);">
                                    <i class="fa fa-trash-can"></i> Clear Cart
                                  </button>
                                </div>
                          </div>

                          <div class="order-summary">
                            <div class="summary-title">Order Summary</div>
                            <div class="summary-row">
                              <span class="label">Subtotal (<span id="summary-count">
                                  <%= cartCount %>
                                </span> items)</span>
                              <span class="value" id="summary-subtotal">₹<%= totalPrice.toLocaleString('en-IN') %>
                                  </span>
                            </div>
                            <div class="summary-row">
                              <span class="label">Delivery</span>
                              <span class="value" id="summary-delivery">₹118</span>
                            </div>
                            <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                            <div class="summary-row discount-row">
                              <span class="label">Coupon Discount (<%= appliedCoupon.code %>)</span>
                              <span class="value discount-amount" style="color: var(--success);">- ₹<%= appliedCoupon.discountAmount.toLocaleString('en-IN') %></span>
                            </div>
                            <% } %>
                            <div class="divider"></div>
                            <div class="coupon-wrap">
                              <span class="coupon-label">Have a coupon?</span>
                              <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                              <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(22, 163, 74, 0.1); border: 1px solid rgba(22, 163, 74, 0.3); border-radius: 7px; padding: 0.6rem 0.9rem; margin-bottom: 0.5rem;">
                                <span style="color: var(--success); font-size: 0.84rem; font-weight: 600;"><%= appliedCoupon.code %> Applied</span>
                                <button onclick="removeCoupon()" style="background: none; border: none; color: var(--success); cursor: pointer; font-size: 0.8rem;">Remove</button>
                              </div>
                              <div style="background: rgba(255,193,7,0.1); border: 1px solid rgba(255,193,7,0.3); border-radius: 7px; padding: 0.6rem 0.9rem; margin-bottom: 0.5rem;">
                                <div style="display: flex; align-items: flex-start; gap: 0.5rem;">
                                  <i class="fa fa-info-circle" style="color: #d97706; font-size: 0.8rem; margin-top: 0.1rem; flex-shrink: 0;"></i>
                                  <div style="color: #d97706; font-size: 0.75rem; line-height: 1.4;">
                                    <strong>Important:</strong> Orders with coupon discounts do not allow individual item cancellation or returns. Only full order cancellation/return is available to ensure fair refund calculation.
                                  </div>
                                </div>
                              </div>
                              <% } else { %>
                              <div class="coupon-input-row">
                                <input type="text" class="coupon-input" id="couponInput" placeholder="Enter code" />
                                <button class="coupon-apply" onclick="applyCoupon()">Apply</button>
                              </div>
                              <% } %>
                              <div class="coupon-msg" id="couponMsg"></div>
                            </div>
                            <div class="summary-row total">
                              <span class="label">Total</span>
                              <span class="value" id="summary-total">₹<%= (typeof finalTotal !== 'undefined' ? finalTotal : totalPrice + 118).toLocaleString('en-IN') %></span>
                            </div>

                            <button class="btn-checkout" onclick="window.location.href='/checkout'" <%=(items.length===0
                              || hasOutOfStock) ? 'disabled' : '' %>>
                              <i class="fa fa-lock"></i> Proceed to Checkout
                            </button>

                            <% if (hasOutOfStock) { %>
                              <div class="oos-checkout-note">
                                <i class="fa fa-circle-exclamation"></i> Remove out of stock items to proceed
                              </div>
                              <% } %>
                                <div class="secure-note"><i class="fa fa-shield-halved"></i> Secure checkout — SSL
                                  encrypted
                                </div>
                          </div>
                        </div>
                        <% } %>
    </div>

    <div id="toast"></div>

    <!-- Clear Cart Modal -->
    <div class="modal-overlay" id="clearCartModal">
      <div class="modal-box">
        <div class="modal-icon">
          <i class="fa fa-trash-can"></i>
        </div>
        <h3 class="modal-title">Clear Your Cart?</h3>
        <p class="modal-text">
          Are you sure you want to remove all items from your cart? This action cannot be undone.
        </p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn-cancel" onclick="closeModal()">Cancel</button>
          <button class="modal-btn modal-btn-confirm" onclick="confirmClearCart()">Yes, Clear Cart</button>
        </div>
      </div>
    </div>

    <!-- Remove Item Modal -->
    <div class="modal-overlay" id="removeItemModal">
      <div class="modal-box">
        <div class="modal-icon">
          <i class="fa fa-trash-can"></i>
        </div>
        <h3 class="modal-title">Remove Item?</h3>
        <p class="modal-text">
          Are you sure you want to remove this item from your cart?
        </p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn-cancel" onclick="closeRemoveModal()">Cancel</button>
          <button class="modal-btn modal-btn-confirm" onclick="confirmRemoveItem()">Yes, Remove</button>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

      <script>
        function showToast(msg, type, duration = 3000) {
          var t = document.getElementById('toast');
          t.textContent = msg;
          
          // Set background color based on type
          if (type === 'success') {
            t.style.background = '#16a34a';
          } else if (type === 'warning') {
            t.style.background = '#d97706';
          } else {
            t.style.background = '#e8411a'; // error
          }
          
          t.style.opacity = '1'; 
          t.style.transform = 'translateY(0)';
          clearTimeout(t._t);
          t._t = setTimeout(function () { 
            t.style.opacity = '0'; 
            t.style.transform = 'translateY(8px)'; 
          }, duration);
        }

        async function updateQty(variantId, newQty) {
          if (newQty < 1) return;
          try {
            const res = await fetch('/cart/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ variantId, quantity: newQty })
            });
            const data = await res.json();
            if (res.ok && data.success) {
              showToast('Cart updated', 'success');
              // Update UI dynamically
              document.getElementById(`qty-${variantId}`).value = newQty;
              document.getElementById(`total-${variantId}`).textContent = '₹' + parseFloat(data.itemTotal).toLocaleString('en-IN');
              document.getElementById('summary-subtotal').textContent = '₹' + parseFloat(data.cartTotal).toLocaleString('en-IN');
              document.getElementById('summary-total').textContent = '₹' + (parseFloat(data.cartTotal) + 118).toLocaleString('en-IN');
              document.getElementById('summary-count').textContent = data.cartCount;
              document.getElementById('summary-delivery').textContent = '₹118';

              // Refresh to handle disabled states of buttons properly without complex DOM manipulation
              setTimeout(() => location.reload(), 400);
            } else {
              showToast(data.message || 'Could not update', 'error');
            }
          } catch {
            showToast('Something went wrong', 'error');
          }
        }

        async function removeItem(variantId) {
          window.pendingRemoveVariantId = variantId;
          document.getElementById('removeItemModal').classList.add('show');
        }

        function closeRemoveModal() {
          document.getElementById('removeItemModal').classList.remove('show');
          window.pendingRemoveVariantId = null;
        }

        async function confirmRemoveItem() {
          const variantId = window.pendingRemoveVariantId;
          closeRemoveModal();

          if (!variantId) return;

          try {
            const res = await fetch('/cart/remove', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ variantId })
            });
            const data = await res.json();
            if (data.success) {
              showToast('Item removed', 'success');
              setTimeout(() => location.reload(), 400);
            }
          } catch {
            showToast('Something went wrong', 'error');
          }
        }

        async function clearCart() {
          document.getElementById('clearCartModal').classList.add('show');
        }

        function closeModal() {
          document.getElementById('clearCartModal').classList.remove('show');
        }

        async function confirmClearCart() {
          closeModal();
          try {
            const res = await fetch('/cart/clear', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
              showToast('Cart cleared', 'success');
              setTimeout(() => location.reload(), 400);
            }
          } catch {
            showToast('Something went wrong', 'error');
          }
        }

        // Close modals on overlay click
        document.getElementById('clearCartModal').addEventListener('click', function (e) {
          if (e.target === this) closeModal();
        });

        document.getElementById('removeItemModal').addEventListener('click', function (e) {
          if (e.target === this) closeRemoveModal();
        });

        // Close modals on Escape key
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            closeModal();
            closeRemoveModal();
          }
        });

        // Auto-uppercase coupon input
        const couponInput = document.getElementById('couponInput');
        if (couponInput) {
          couponInput.addEventListener('input', function(e) {
            this.value = this.value.toUpperCase();
          });
        }

        function applyCoupon() {
          const code = document.getElementById('couponInput').value.trim();
          const msg = document.getElementById('couponMsg');
          
          if (!code) { 
            msg.textContent = 'Please enter a coupon code.'; 
            msg.className = 'coupon-msg error'; 
            return; 
          }

          // Show loading state
          const applyBtn = document.querySelector('.coupon-apply');
          const originalText = applyBtn.textContent;
          applyBtn.textContent = 'Applying...';
          applyBtn.disabled = true;

          fetch('/cart/apply-coupon', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ couponCode: code })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              showToast(data.message, 'success');
              setTimeout(() => location.reload(), 800);
            } else {
              msg.textContent = data.message;
              msg.className = 'coupon-msg error';
            }
          })
          .catch(() => {
            msg.textContent = 'Something went wrong. Please try again.';
            msg.className = 'coupon-msg error';
          })
          .finally(() => {
            applyBtn.textContent = originalText;
            applyBtn.disabled = false;
          });
        }

        function removeCoupon() {
          fetch('/cart/remove-coupon', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              showToast(data.message, 'success');
              setTimeout(() => location.reload(), 400);
            }
          })
          .catch(() => {
            showToast('Something went wrong', 'error');
          });
        }
      </script>

</body>

</html>