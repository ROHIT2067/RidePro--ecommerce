<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - RidePro</title>
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/login.css">
  <link rel="stylesheet" href="/styles/footer.css">
</head>

<body>

  <%- include('partials/header') %>

    <main class="main-content">
      <div class="content-header">
        <div class="breadcrumb">RidePro &gt; Login</div>
        <h1>Login</h1>
      </div>

      <div class="login-form-container">

        <a href="/auth/google" class="google-btn">
          <svg class="google-icon" viewBox="0 0 24 24">
            <path fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
            <path fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          Continue with Google
        </a>

        <div class="separator"><span>OR</span></div>

        <form action="/login" method="POST" id="loginForm" novalidate>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required <% if (typeof loginErr !=='undefined' && loginErr) {
              %>class="error"<% } %> />
              <% if (typeof loginErr !=='undefined' && loginErr) { %>
                <div class="field-error">
                  <%= loginErr %>
                </div>
                <% } %>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <div style="position:relative;">
              <input type="password" id="password" name="password" required <% if (typeof loginErr1 !=='undefined' &&
                loginErr1) { %>class="error"<% } %>
                style="padding-right:40px;" />
                <span id="togglePassword" aria-label="Toggle password visibility" style="
              position:absolute; right:10px; top:50%;
              transform:translateY(-50%); cursor:pointer;
              display:flex; align-items:center;">
                  <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                    viewBox="0 0 24 24">
                    <path
                      d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z" />
                  </svg>
                </span>
            </div>
            <% if (typeof loginErr1 !=='undefined' && loginErr1) { %>
              <div class="field-error">
                <%= loginErr1 %>
              </div>
              <% } %>
          </div>

          <div class="forgot-password">
            <a href="/forgot-password">Forgot Password?</a>
          </div>

          <button type="submit" class="submit-btn">Login</button>
        </form>

        <div class="signup-link">
          Don't have an account? <a href="/signup">Sign up</a>
        </div>

      </div>
    </main>

    <%- include('partials/footer') %>

      <script>
        const passwordInput = document.getElementById("password");
        const toggle = document.getElementById("togglePassword");
        const eyeIcon = document.getElementById("eyeIcon");

        toggle.addEventListener("click", () => {
          const isHidden = passwordInput.type === "password";
          passwordInput.type = isHidden ? "text" : "password";
          eyeIcon.innerHTML = isHidden
            ? '<path d="M1.5 1.5l21 21M9.53 9.53A3 3 0 0012 15a3 3 0 002.47-5.47M12 5c-7.633 0-12 7-12 7a21.77 21.77 0 005.17 5.17M18.83 18.83A21.77 21.77 0 0024 12s-4.367-7-12-7a11.9 11.9 0 00-3.29.45"/>'
            : '<path d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z"/>';
        });
      </script>

</body>

</html>