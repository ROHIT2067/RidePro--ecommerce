<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RidePro — Premium Riding Gear</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/footer.css" />
  <link rel="stylesheet" href="/Styles/home.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- ══════════════════════════════════════════════════════════════
       HERO CAROUSEL
       To add your own background images, go to the CSS above and
       replace the background gradient in .carousel-slide:nth-child(n)
       with:
         background-image: url('/images/hero1.jpg');
         background-size: cover;
         background-position: center;
  ══════════════════════════════════════════════════════════════ -->
  <section class="carousel" id="heroCarousel">
    <div class="carousel-track" id="carouselTrack">

      <!-- Slide 1 -->
      <div class="carousel-slide active">
        <span class="slide-badge">New 2025 Collection</span>
        <div class="slide-content">
          <p class="slide-eyebrow">Premium Riding Gear</p>
          <h1 class="slide-title">Gear Up.<span>Ride Hard.</span></h1>
          <p class="slide-sub">Built for riders who refuse to compromise. Every stitch, every buckle engineered for performance and protection.</p>
          <div class="slide-actions">
            <a href="/products" class="btn-primary">Explore Gear →</a>
          </div>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="carousel-slide">
        <span class="slide-badge">Best Sellers</span>
        <div class="slide-content">
          <p class="slide-eyebrow">Top Rated Helmets</p>
          <h1 class="slide-title">Protect<span>Your Ride.</span></h1>
          <p class="slide-sub">ISI & ECE certified helmets trusted by thousands of riders across India.</p>
          <div class="slide-actions">
            <% const helmetCategory = categories.find(cat => cat.name === 'Helmets'); %>
            <a href="/products<%= helmetCategory ? '?category=' + helmetCategory._id : '' %>" class="btn-primary">Shop Helmets →</a>
          </div>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="carousel-slide">
        <span class="slide-badge">New Arrivals</span>
        <div class="slide-content">
          <p class="slide-eyebrow">Riding Jackets & Suits</p>
          <h1 class="slide-title">Armored.<span>Ready.</span></h1>
          <p class="slide-sub">CE-certified armored jackets and suits for every type of rider and every road.</p>
          <div class="slide-actions">
            <% const jacketCategory = categories.find(cat => cat.name === 'Jackets'); %>
            <a href="/products<%= jacketCategory ? '?category=' + jacketCategory._id : '' %>" class="btn-primary">Shop Jackets →</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Dot Controls -->
    <div class="carousel-dots" id="carouselDots">
      <button class="dot active" data-index="0"></button>
      <button class="dot" data-index="1"></button>
      <button class="dot" data-index="2"></button>
    </div>
  </section>

  <!-- ── STATS ── -->
  <div class="stats-bar">
    <div class="stat"><div class="stat-value">12+</div><div class="stat-label">Products</div></div>
    <div class="stat"><div class="stat-value">18K+</div><div class="stat-label">Happy Riders</div></div>
    <div class="stat"><div class="stat-value">4.9★</div><div class="stat-label">Avg Rating</div></div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       SHOP BY CATEGORY
       Replace each <img src="..."> with your actual category photo.
       Recommended image size: 800x600px
       Example: src="/images/categories/helmets.jpg"
  ══════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Shop by <em>Category</em></h2>
    </div>
    <div class="categories">
  <%
    const catImages = {
  Helmets:   '/Images/LandingPage/helmet.jpg',
  Jackets:   '/Images/LandingPage/Jacket.heic',
  Gloves:    '/Images/LandingPage/Gloves1.jpg',
  Boots:     '/Images/LandingPage/boots.jpg',
  Pants:     '/Images/LandingPage/pants.heic',
  LifeStyle: '/Images/LandingPage/lifestyle.jpg'
};
  %>
  <% categories.forEach(cat => { %>
    <a href="/products?category=<%= cat._id %>" class="category-card">
      <img class="cat-img" src="<%= catImages[cat.name] || '/images/categories/default.jpg' %>" alt="<%= cat.name %>" />
      <div class="cat-body">
        <div class="cat-name"><%= cat.name %></div>
        <div class="cat-count">Browse Products</div>
        <span class="cat-arrow">→</span>
      </div>
    </a>
  <% }) %>
</div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FEATURED GEAR
       Replace each <img src="..."> with your actual product photo.
       Recommended image size: 600x600px (square)
       Example: src="/images/products/helmet-aeroshield.jpg"
  ══════════════════════════════════════════════════════════════ -->
  <section class="section" style="padding-top: 0;">
    <div class="section-header">
      <h2 class="section-title"><em>Featured</em> Gear</h2>
      <a href="/products" class="section-link">View All →</a>
    </div>
    <div class="products-grid">
  <% featuredProducts.forEach(({ product, minPrice, maxPrice, firstImage, isNew }) => { %>
    <a href="/product/<%= product._id %>" class="product-card">
      <% if (firstImage) { %>
        <img class="product-img" src="<%= firstImage %>" alt="<%= product.productName %>" loading="lazy" />
      <% } else { %>
        <img class="product-img" src="https://placehold.co/600x600/161616/555555?text=No+Image" alt="<%= product.productName %>" />
      <% } %>
      <% if (isNew) { %><div class="product-badge">New</div><% } %>
      <div class="product-info">
        <div class="product-category"><%= product.category ? product.category.name : '' %></div>
        <div class="product-name"><%= product.productName %></div>
        <div class="product-footer">
          <div class="product-price">
            ₹<%= minPrice.toLocaleString('en-IN') %>
            <% if (maxPrice > minPrice) { %>
              <span style="font-size:0.75rem;color:#888;font-weight:400"> – ₹<%= maxPrice.toLocaleString('en-IN') %></span>
            <% } %>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
  </section>

  <!-- ── TRUST FEATURES ── -->
  <section class="section" style="padding-top: 0;">
    <div class="features">
      <div class="feature">
        <div class="feature-icon">🚚</div>
        <div class="feature-title">Free Shipping</div>
        <div class="feature-desc">On all orders above ₹1,999. Fast delivery across India within 3–5 business days.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">🛡️</div>
        <div class="feature-title">Certified Safety</div>
        <div class="feature-desc">All helmets and protective gear are ISI / DOT / ECE certified for your safety.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">🔄</div>
        <div class="feature-title">Easy Returns</div>
        <div class="feature-desc">7-day hassle-free returns. Wrong size? We'll exchange it, no questions asked.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">💬</div>
        <div class="feature-title">Rider Support</div>
        <div class="feature-desc">Expert support from fellow riders available 9AM–9PM, 7 days a week.</div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <!-- ── CAROUSEL SCRIPT ── -->
  <script>
    const track = document.getElementById('carouselTrack');
    const slides = track.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.dot');
    let current = 0;
    let autoTimer;

    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      track.style.transform = `translateX(-${current * 100}%)`;
    }

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        clearInterval(autoTimer);
        goTo(parseInt(dot.dataset.index));
        startAuto();
      });
    });

    function startAuto() {
      autoTimer = setInterval(() => goTo(current + 1), 5000);
    }

    startAuto();
  </script>

</body>
</html>