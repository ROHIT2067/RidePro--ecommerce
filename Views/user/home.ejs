<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RidePro - Motorcycle Gear</title>
     <link rel="stylesheet" href="/Styles/home.css">
</head>
<body>
    <!-- Header -->
    <header>
        <a href="/home" class="logo">RidePro</a>
        <div class="nav-right">
            <a href="#" class="nav-item">
                <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                <span>Search</span>
            </a>
            <a href="#" class="nav-item">
                <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042H6.14l.94-2.846 1.952.012L7.043 16H17a1 1 0 000-2H8.245l-.166-.67 6.76-.001.946-2.855L17.5 3H3z"/>
                </svg>
                <span>Cart</span>
            </a>
            <a href="/account" class="nav-item">
                <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                </svg>
                <span>Profile</span>
            </a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section">
        <img class="hero-image" src="https://images.unsplash.com/photo-1558981359-219d6364c9c8?w=1600&q=80" alt="AIR GT PANTS - Motorcycle gear"/>
        <div class="hero-overlay">
            <h1 class="hero-title">AIR GT PANTS</h1>
            <p class="hero-subtitle">The Full Collection.</p>
            <button type="button" class="explore-btn">Explore now</button>
        </div>
        <button type="button" class="hero-arrow prev" aria-label="Previous">
            <svg width="24" height="24" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        </button>
        <button type="button" class="hero-arrow next" aria-label="Next">
            <svg width="24" height="24" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
        </button>
        <div class="hero-dots">
            <span class="hero-dot active"></span>
            <span class="hero-dot"></span>
            <span class="hero-dot"></span>
        </div>
    </section>

    <!-- Category Grid -->
    <section class="category-grid">
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?w=600&q=80" alt="Offroad"/>
            <span class="category-label">OFFROAD</span>
        </div>
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=600&q=80" alt="Gloves"/>
            <span class="category-label">GLOVES</span>
        </div>
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80" alt="Jackets"/>
            <span class="category-label">JACKETS</span>
        </div>
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&q=80" alt="Base Layers"/>
            <span class="category-label">BASE LAYERS</span>
        </div>
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1624378515195-6bbdb73deb6e?w=600&q=80" alt="Pants"/>
            <span class="category-label">PANTS</span>
        </div>
        <div class="category-item">
            <img src="https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?w=600&q=80" alt="Luggage"/>
            <span class="category-label">LUGGAGE</span>
        </div>
    </section>

    <!-- Get Monsoon Ready Banner -->
    <section class="monsoon-banner" style="position: relative;">
        <button type="button" class="banner-arrows prev" aria-label="Previous" style="z-index: 2;">&#10094;</button>
        <button type="button" class="banner-arrows next" aria-label="Next" style="z-index: 2;">&#10095;</button>
        <div class="monsoon-left">
            <img src="https://images.unsplash.com/photo-1568772585407-9361f9bf3a87?w=800&q=80" alt="Get Monsoon Ready"/>
            <div class="monsoon-overlay">
                <h2>GET MONSOON READY</h2>
                <button type="button" class="explore-btn">Explore now</button>
            </div>
        </div>
        <div class="monsoon-right">
            <h3 class="monsoon-product-title">H2GO PRO RAIN JACKET</h3>
            <p class="monsoon-price">₹ 1,399</p>
            <div class="monsoon-thumbnails">
                <img class="monsoon-thumb" src="https://images.unsplash.com/photo-1551028719-00167b16eac5?w=150&q=80" alt="Jacket"/>
                <img class="monsoon-thumb" src="https://images.unsplash.com/photo-1624378515195-6bbdb73deb6e?w=150&q=80" alt="Pants"/>
                <img class="monsoon-thumb" src="https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=150&q=80" alt="Gloves"/>
                <img class="monsoon-thumb" src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=150&q=80" alt="Boots"/>
            </div>
        </div>
    </section>

    <!-- Main Showcase Banner -->
    <section class="showcase-banner" style="position: relative;">
        <button type="button" class="hero-arrow prev" aria-label="Previous" style="left: 1.5rem;">&#10094;</button>
        <button type="button" class="hero-arrow next" aria-label="Next" style="right: 1.5rem;">&#10095;</button>
        <img src="https://images.unsplash.com/photo-1547549082-6bc5f2f6c2fa?w=1600&q=80" alt="RidePro Adventure"/>
        <span class="showcase-logo">RidePro</span>
        <button type="button" class="scroll-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Scroll to top">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
        </button>
    </section>

    <!-- Product Detail: H2GO PRO RAIN PANTS -->
    <section class="product-detail-section">
        <div>
            <img class="product-detail-image" src="https://images.unsplash.com/photo-1624378515195-6bbdb73deb6e?w=600&q=80" alt="H2GO PRO RAIN PANTS"/>
        </div>
        <div class="product-detail-info">
            <h2>H2GO PRO RAIN PANTS</h2>
            <div class="product-rating">
                <span class="stars">★★★★★</span>
                <a href="#" class="reviews-link">9 Reviews</a>
            </div>
            <p>Water-resistant riding pants built for monsoon. Lightweight and packable.</p>
            <p class="price">₹ 1,399</p>
            <div class="product-options">
                <select name="size" id="size" aria-label="Size">
                    <option value="">Select Size</option>
                    <option value="S">S</option>
                    <option value="M">M</option>
                    <option value="L">L</option>
                    <option value="XL">XL</option>
                </select>
                <select name="quantity" id="quantity" aria-label="Quantity">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                </select>
            </div>
            <button type="button" class="add-to-cart-btn">Add To Cart</button>
        </div>
        <button type="button" class="scroll-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Scroll to top">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
        </button>
    </section>

    <!-- Footer -->
     <%- include('partials/footer') %>
    <!-- <script>
  window.addEventListener("pageshow", function (event) {
    if (event.persisted) {
      window.location.reload(); // forces reload from server, not cache
    }
  });
</script> -->
<div id="toast" class="toast hidden"></div>

<script>
  const params = new URLSearchParams(window.location.search);
  const toastType = params.get("toast");

  if (toastType === "already_logged_in") {
    showToast("You are already logged in. Logout to switch accounts.");
  }

  function showToast(message) {
    const toast = document.getElementById("toast");
    toast.textContent = message;
    toast.classList.remove("hidden");
    toast.classList.add("show");

    setTimeout(() => {
      toast.classList.remove("show");
      toast.classList.add("hidden");
    }, 3000);
  }
</script>

</body>
</html>
