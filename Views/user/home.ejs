                <div class="product-thumbnails">
                    <img src="https://images.unsplash.com/photo-1558980664-769d59546b3d?w=200&h=200&fit=crop" alt="Jacket" class="thumbnail active">
                    <img src="https://images.unsplash.com/photo-1558980664-1db506751c6c?w=200&h=200&fit=crop" alt="Pants" class="thumbnail">
                    <img src="https://images.unsplash.com/photo-1558980664-769d59546b3d?w=200&h=200&fit=crop" alt="Boots" class="thumbnail">
                    <img src="https://images.unsplash.com/photo-1558980664-1db506751c6c?w=200&h=200&fit=crop" alt="Gloves" class="thumbnail">
                </div>
                <div class="carousel-dots">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            </div>
        </div>
    </section>

    <!-- Promotional Banner -->
    <section class="promo-banner">
        <img src="https://images.unsplash.com/photo-1558980664-769d59546b3d?w=1920&h=600&fit=crop" alt="Adventure Motorcycle">
    </section>

    <!-- Product Detail Section -->
    <section class="product-detail-section">
        <div class="product-detail-container">
            <div class="product-detail-left">
                <img src="https://images.unsplash.com/photo-1558980664-1db506751c6c?w=800&h=1000&fit=crop" alt="H2GO Pro Rain Pants" class="product-detail-image">
                <button class="carousel-nav prev">
                    <svg fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                </button>
                <button class="carousel-nav next">
                    <svg fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                    </svg>
                </button>
                <div class="carousel-dots" style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            </div>
            <div class="product-detail-right">
                <h2 class="product-detail-name">H2GO PRO RAIN PANTS</h2>
                <div class="product-rating">
                    <span class="stars">★★★★★</span>
                    <span class="reviews">5 Reviews</span>
                </div>
                <p class="product-description">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                </p>
                <div class="product-price">$XXXX</div>
                <div class="product-options">
                    <div class="option-group">
                        <label for="size">Size</label>
                        <select id="size" class="option-input">
                            <option>Select Size</option>
                            <option>Small</option>
                            <option>Medium</option>
                            <option>Large</option>
                            <option>X-Large</option>
                        </select>
                    </div>
                    <div class="option-group">
                        <label for="color">Color</label>
                        <select id="color" class="option-input">
                            <option>Select Color</option>
                            <option>Black</option>
                            <option>Grey</option>
                            <option>Navy</option>
                        </select>
                    </div>
                </div>
                <button class="add-to-cart-btn">ADD TO CART</button>
                <p class="product-info-text">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-mountain"></div>
        <div class="footer-content">
            <div class="footer-grid">
