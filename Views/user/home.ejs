<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RidePRO – Air GT Pants</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background-color: #000;
      color: #fff;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    /* Layout helpers */
    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background-color: #000;
    }

    .wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Header */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 20;
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(6px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .header-inner {
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo-mark {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.9rem;
    }

    .logo-circle {
      width: 32px;
      height: 32px;
      border-radius: 999px;
      background: #fff;
      color: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    .main-nav {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      font-size: 0.9rem;
    }

    .main-nav a {
      opacity: 0.85;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 500;
    }

    .main-nav a:hover {
      opacity: 1;
    }

    .nav-cta {
      padding: 0.45rem 1rem;
      border-radius: 999px;
      border: 1px solid #e5ff00;
      color: #e5ff00;
      text-transform: uppercase;
      font-size: 0.8rem;
    }

    /* Hero section */
    .hero {
      margin-top: 64px;
      position: relative;
      height: 90vh;
      min-height: 540px;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.1)),
        url('https://images.pexels.com/photos/337909/pexels-photo-337909.jpeg?auto=compress&cs=tinysrgb&w=1600');
      background-size: cover;
      background-position: center;
      transform: scale(1.05);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      height: 100%;
      display: flex;
      align-items: flex-end;
      padding-bottom: 4rem;
    }

    .hero-text {
      max-width: 440px;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.14);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 0.75rem;
    }

    .hero-tag-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #e5ff00;
    }

    .hero-title {
      font-size: clamp(2.5rem, 4vw, 3.3rem);
      line-height: 1.1;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .hero-subtitle {
      font-size: 0.95rem;
      color: #f3f3f3;
      opacity: 0.85;
      max-width: 380px;
      margin-bottom: 1.5rem;
    }

    .hero-ctas {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .btn-primary {
      padding: 0.8rem 1.8rem;
      border-radius: 999px;
      border: none;
      background: #e5ff00;
      color: #000;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.8rem;
      cursor: pointer;
    }

    .btn-secondary {
      padding: 0.8rem 1.5rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.3);
      background: transparent;
      color: #fff;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.8rem;
      cursor: pointer;
    }

    .hero-meta {
      margin-top: 1.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      opacity: 0.8;
    }

    /* Grid categories */
    .section {
      background: #050505;
    }

    .section.light {
      background: #f5f5f5;
      color: #111;
    }

    .section + .section {
      border-top: 1px solid #111;
    }

    .section-inner {
      padding: 4rem 0;
    }

    .grid-heading {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      margin-bottom: 1.5rem;
      color: #b3b3b3;
    }

    .category-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      grid-auto-rows: 180px;
      gap: 0.75rem;
    }

    .category-card {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
      background: #111;
      cursor: pointer;
    }

    .category-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transform: scale(1.05);
      transition: transform 0.3s ease;
      opacity: 0.9;
    }

    .category-card[data-bg="adventure"]::before {
      background-image: url('https://images.pexels.com/photos/100582/pexels-photo-100582.jpeg?auto=compress&cs=tinysrgb&w=1600');
    }

    .category-card[data-bg="urban"]::before {
      background-image: url('https://images.pexels.com/photos/1335077/pexels-photo-1335077.jpeg?auto=compress&cs=tinysrgb&w=1600');
    }

    .category-card[data-bg="touring"]::before {
      background-image: url('https://images.pexels.com/photos/1149137/pexels-photo-1149137.jpeg?auto=compress&cs=tinysrgb&w=1600');
    }

    .category-card[data-bg="commute"]::before {
      background-image: url('https://images.pexels.com/photos/237704/pexels-photo-237704.jpeg?auto=compress&cs=tinysrgb&w=1600');
    }

    .category-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
      display: flex;
      align-items: flex-end;
      padding: 1.2rem;
    }

    .category-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.75rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid #e5ff00;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }

    .category-card:hover::before {
      transform: scale(1.09);
    }

    /* Highlight section (neon yellow rain gear) */
    .highlight {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
      gap: 2.5rem;
      align-items: center;
    }

    .highlight-media {
      border-radius: 14px;
      overflow: hidden;
      background: #111;
      min-height: 260px;
      background-image: url('https://images.pexels.com/photos/11281099/pexels-photo-11281099.jpeg?auto=compress&cs=tinysrgb&w=1600');
      background-size: cover;
      background-position: center;
      position: relative;
    }

    .highlight-media::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top right, rgba(0,0,0,0.65), transparent);
    }

    .highlight-text {
      max-width: 360px;
    }

    .highlight-kicker {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 0.6rem;
      color: #a2a2a2;
    }

    .highlight-title {
      font-size: 1.7rem;
      text-transform: uppercase;
      margin-bottom: 0.7rem;
    }

    .highlight-body {
      font-size: 0.95rem;
      color: #dcdcdc;
      margin-bottom: 1.4rem;
    }

    .highlight-meta {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #e5ff00;
      margin-bottom: 1.3rem;
    }

    /* Wide hero ride shot */
    .ride-shot {
      border-radius: 14px;
      overflow: hidden;
      height: 340px;
      background-image: url('https://images.pexels.com/photos/2582936/pexels-photo-2582936.jpeg?auto=compress&cs=tinysrgb&w=1600');
      background-size: cover;
      background-position: center;
      position: relative;
    }

    .ride-shot::after {
      content: "MONSOON PACKED";
      position: absolute;
      left: 2.5rem;
      bottom: 2.2rem;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid #e5ff00;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }

    /* Product details section */
    .product {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
      gap: 3rem;
      align-items: center;
    }

    .product-media {
      background: #111;
      border-radius: 18px;
      padding: 2.5rem 1.8rem;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .product-media-inner {
      max-width: 280px;
    }

    .product-media-inner img {
      filter: drop-shadow(0 18px 26px rgba(0, 0, 0, 0.9));
    }

    .product-info-kicker {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #a2a2a2;
      margin-bottom: 0.5rem;
    }

    .product-title {
      font-size: 1.9rem;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      color: #111;
    }

    .product-subtitle {
      font-size: 0.95rem;
      color: #4b4b4b;
      margin-bottom: 1.1rem;
    }

    .product-price {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: #111;
    }

    .product-form {
      display: grid;
      gap: 1rem;
      max-width: 360px;
    }

    .field-label {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #777;
      margin-bottom: 0.25rem;
    }

    .product-form-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    select,
    input[type="number"] {
      width: 100%;
      padding: 0.7rem 0.8rem;
      border-radius: 999px;
      border: 1px solid #cfcfcf;
      font-size: 0.9rem;
      background: #fff;
      color: #111;
      outline: none;
    }

    select:focus,
    input[type="number"]:focus {
      border-color: #111;
    }

    .product-btns {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 0.4rem;
    }

    .btn-buy {
      flex: 1;
      border-radius: 999px;
      border: none;
      padding: 0.85rem 1rem;
      background: #111;
      color: #fff;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      cursor: pointer;
    }

    .btn-buy:hover {
      background: #000;
    }

    .btn-outline {
      border-radius: 999px;
      border: 1px solid #111;
      padding: 0.8rem 1.1rem;
      background: transparent;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      cursor: pointer;
    }

    .product-note {
      margin-top: 0.9rem;
      font-size: 0.78rem;
      color: #777;
    }

    /* Footer (re-using look from login) */
    footer {
      background-color: #111;
      color: white;
      padding-top: 3rem;
      margin-top: 4rem;
    }

    .footer-graphic {
      height: 80px;
      background: linear-gradient(to bottom, transparent, #111),
        url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 200"><path d="M0,100 Q300,50 600,100 T1200,100 L1200,200 L0,200 Z" fill="%23111111"/></svg>');
      background-size: cover;
      margin-bottom: 2rem;
    }

    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem 2.5rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
    }

    .footer-section h3 {
      font-size: 0.9rem;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .footer-section ul {
      list-style: none;
    }

    .footer-section ul li {
      margin-bottom: 0.5rem;
      font-size: 0.85rem;
      color: #ccc;
    }

    .footer-section ul li a {
      color: #ccc;
      text-decoration: none;
    }

    .footer-section ul li a:hover {
      color: #fff;
    }

    .footer-section p {
      color: #ccc;
      font-size: 0.85rem;
      line-height: 1.6;
      margin-bottom: 0.5rem;
    }

    .footer-bottom {
      border-top: 1px solid #222;
      padding: 1.4rem 1.5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.8rem;
      color: #7a7a7a;
    }

    .footer-social {
      display: flex;
      gap: 1rem;
    }

    .footer-social a {
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: #1f1f1f;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      opacity: 0.7;
    }

    .footer-social a:hover {
      opacity: 1;
    }

    /* Responsive tweaks */
    @media (max-width: 960px) {
      .category-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .highlight,
      .product {
        grid-template-columns: minmax(0, 1fr);
      }
      .ride-shot {
        height: 260px;
      }
      .hero {
        height: auto;
        min-height: 480px;
      }
      .hero-content {
        align-items: flex-end;
      }
    }

    @media (max-width: 720px) {
      .header-inner {
        justify-content: space-between;
      }
      .main-nav {
        gap: 1rem;
        font-size: 0.8rem;
      }
      .hero-content {
        padding-bottom: 3rem;
      }
      .hero-text {
        max-width: 100%;
      }
      .footer-bottom {
        flex-direction: column;
        gap: 0.75rem;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <!-- Header -->
    <header>
      <div class="wrapper header-inner">
        <a href="/" class="logo-mark">
          <div class="logo-circle">R</div>
          <span>RidePRO</span>
        </a>
        <nav class="main-nav">
          <a href="#categories">Gear</a>
          <a href="#rain">Monsoon</a>
          <a href="#product">Featured</a>
          <a href="/login">Login</a>
          <a href="/signup" class="nav-cta">Sign up</a>
        </nav>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="wrapper hero-content">
        <div class="hero-text">
          <div class="hero-tag">
            <span class="hero-tag-dot"></span>
            <span>New launch</span>
          </div>
          <h1 class="hero-title">Air GT Pants</h1>
          <p class="hero-subtitle">
            All–season touring pants with intelligent ventilation and impact protection,
            built for riders who don’t wait for perfect weather.
          </p>
          <div class="hero-ctas">
            <form action="/products/air-gt-pants" method="GET">
              <button type="submit" class="btn-primary">View details</button>
            </form>
            <a href="#product">
              <button type="button" class="btn-secondary">Explore monsoon pack</button>
            </a>
          </div>
          <div class="hero-meta">
            <span>CE Level 2 armour</span>
            <span>All-weather shell</span>
            <span>Touring fit</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Category grid -->
    <section id="categories" class="section">
      <div class="wrapper section-inner">
        <div class="grid-heading">Ride your way</div>
        <div class="category-grid">
          <a href="/products?category=adventure" class="category-card" data-bg="adventure">
            <div class="category-overlay">
              <span class="category-label">Adventure</span>
            </div>
          </a>
          <a href="/products?category=urban" class="category-card" data-bg="urban">
            <div class="category-overlay">
              <span class="category-label">Urban</span>
            </div>
          </a>
          <a href="/products?category=touring" class="category-card" data-bg="touring">
            <div class="category-overlay">
              <span class="category-label">Touring</span>
            </div>
          </a>
          <a href="/products?category=commute" class="category-card" data-bg="commute">
            <div class="category-overlay">
              <span class="category-label">Commute</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Highlight section (neon rain gear) -->
    <section id="rain" class="section light">
      <div class="wrapper section-inner">
        <div class="highlight">
          <div class="highlight-media"></div>
          <div class="highlight-text">
            <div class="highlight-kicker">Monsoon Essentials</div>
            <h2 class="highlight-title">H2GO Rain Pack</h2>
            <p class="highlight-body">
              Bright, packable protection that keeps you visible and bone‑dry when
              the skies open up. Built to layer over your existing riding gear.
            </p>
            <div class="highlight-meta">Jackets · Pants · Boot covers · Gloves</div>
            <a href="/products?tag=rain">
              <button type="button" class="btn-primary">Shop monsoon gear</button>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Wide ride shot -->
    <section class="section">
      <div class="wrapper section-inner">
        <div class="ride-shot"></div>
      </div>
    </section>

    <!-- Product detail card -->
    <section id="product" class="section light">
      <div class="wrapper section-inner">
        <div class="product">
          <div class="product-media">
            <div class="product-media-inner">
              <!-- Replace with your own product image -->
              <img src="https://images.pexels.com/photos/5634939/pexels-photo-5634939.jpeg?auto=compress&cs=tinysrgb&w=800"
                   alt="H2GO Pro Rain Pants" />
            </div>
          </div>
          <div class="product-info">
            <div class="product-info-kicker">Featured product</div>
            <h2 class="product-title">H2GO Pro Rain Pants</h2>
            <p class="product-subtitle">
              Lightweight, fully seam–sealed overpants designed to slip on in seconds
              and keep you dry for the long haul.
            </p>
            <div class="product-price">
              ₹ <%= typeof price !== 'undefined' ? price : '4,999' %>
            </div>

            <form action="/cart/add" method="POST" class="product-form">
              <!-- Required by backend: product id & redirect route -->
              <input type="hidden" name="productId" value="<%= typeof productId !== 'undefined' ? productId : 'h2go-pro-rain-pants' %>" />
              <input type="hidden" name="redirectTo" value="/checkout" />

              <div>
                <div class="field-label">Size</div>
                <select name="size" required>
                  <option value="" disabled selected hidden>Select size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="2XL">2XL</option>
                </select>
              </div>

              <div class="product-form-row">
                <div>
                  <div class="field-label">Color</div>
                  <select name="color" required>
                    <option value="neon-black">Neon / Black</option>
                    <option value="stealth-black">Stealth Black</option>
                  </select>
                </div>
                <div>
                  <div class="field-label">Qty</div>
                  <input
                    type="number"
                    name="quantity"
                    min="1"
                    max="5"
                    value="1"
                    required
                  />
                </div>
              </div>

              <div class="product-btns">
                <button type="submit" class="btn-buy">Add to cart</button>
                <button type="button" class="btn-outline" onclick="window.location.href='/products/h2go-pro-rain-pants'">
                  View full details
                </button>
              </div>

              <p class="product-note">
                Free shipping above ₹2,000 · 7‑day exchange · Designed &amp; tested in India
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="footer-graphic"></div>
      <div class="footer-content">
        <div class="footer-section">
          <h3>Store</h3>
          <ul>
            <li><a href="/products?category=protective-gear">Protective gear</a></li>
            <li><a href="/products?category=layers">Performance layers</a></li>
            <li><a href="/products?category=luggage">Luggage</a></li>
            <li><a href="/products?category=accessories">Accessories</a></li>
            <li><a href="/products?category=lifestyle">Lifestyle merch</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h3>Support</h3>
          <ul>
            <li><a href="/support/shipping">Shipping policy</a></li>
            <li><a href="/support/warranty">Warranty</a></li>
            <li><a href="/support/refund">Refund / exchange policy</a></li>
            <li><a href="/support/care">Care instructions</a></li>
            <li><a href="/support/insurance">Wingman insurance</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h3>Contact</h3>
          <p>Contact Number: +91 7795680016</p>
          <p>Mon–Fri 11:00 AM to 4:30 PM</p>
          <p>For any queries please contact <a href="/support">Customer Support</a></p>
        </div>
