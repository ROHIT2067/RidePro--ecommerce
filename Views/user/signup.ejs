                </svg>
                Continue with Google
            </a>

            <!-- Separator -->
            <div class="separator">
                <span>OR</span>
            </div>

            <!-- Signup Form -->
            <form novalidate action="/signup" method="POST" id="signupForm">
                <div class="form-group">
                    <label for="username">Name</label>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        required
                        
                    />
                    <div id="err1" class="error-message"></div>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required
                    />
                    <div id="err2" class="error-message"></div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required
                        
                    />
                    <div id="err3" class="error-message"></div>
                </div>

                <div class="form-group">
                    <label for="phoneNumber">Mobile</label>
                    <input 
                        type="tel" 
                        id="phoneNumber" 
                        name="phoneNumber" 
                        required
                        
                        
                    />
                    <div id="err4" class="error-message"></div>
                </div>

                <div class="form-group">
                    <label for="referralCode">
                        Referral Code 
                        <span class="optional-label">(Optional)</span>
                    </label>
                    <input 
                        type="text" 
                        id="referralCode" 
                        name="referralCode"
                    />
                </div>

                <div class="terms-text">
                    By Creating An Account You Agree With Our 
                    <a href="/terms">Terms Of Service</a>, 
                    <a href="/privacy">Privacy Policy</a>.
                </div>

                <button type="submit" class="submit-btn">Create account</button>
            </form>

            <div class="login-link">
                Already have an account? <a href="/login">Log in</a>
            </div>
        </div>
    </main>

