<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Orders — RidePro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/header.css" />
  <link rel="stylesheet" href="/styles/footer.css" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0d0d0d; --surface: #141414; --surface2: #1c1c1c; --surface3: #222;
      --border: #2a2a2a; --border2: #333; --text: #f0f0f0; --muted: #888; --muted2: #555;
      --accent: #e8411a; --accent2: #ff5733; --success: #16a34a; --danger: #ef4444;
      --font: 'DM Sans', sans-serif; --display: 'Bebas Neue', sans-serif;
      --radius: 10px; --radius2: 14px;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; padding-top: 72px; }
    .page-wrap { max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }
    .page-title { font-family: var(--display); font-size: 2.6rem; letter-spacing: 0.04em; margin-bottom: 0.4rem; }
    .page-title em { color: var(--accent); font-style: normal; }
    .page-subtitle { font-size: 0.84rem; color: var(--muted); margin-bottom: 2rem; }
    .search-bar { margin-bottom: 2rem; }
    .search-form { display: flex; gap: 0.5rem; max-width: 500px; }
    .search-input { flex: 1; padding: 0.75rem 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-family: var(--font); font-size: 0.88rem; }
    .search-input:focus { outline: none; border-color: var(--accent); }
    .search-btn { padding: 0.75rem 1.5rem; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-family: var(--font); font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .search-btn:hover { background: var(--accent2); }
    .clear-search { padding: 0.75rem 1rem; background: var(--surface3); color: var(--text); border: 1px solid var(--border2); border-radius: 8px; font-family: var(--font); font-size: 0.88rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: background 0.15s; }
    .clear-search:hover { background: var(--border2); }
    .order-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); padding: 1.5rem; margin-bottom: 1.5rem; transition: border-color 0.2s; }
    .order-card:hover { border-color: var(--border2); }
    .order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .order-id { font-family: var(--display); font-size: 1.2rem; letter-spacing: 0.04em; }
    .order-date { font-size: 0.8rem; color: var(--muted); }
    .order-body { display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: center; }
    .order-info { display: flex; gap: 2rem; }
    .info-item { display: flex; flex-direction: column; gap: 0.3rem; }
    .info-label { font-size: 0.76rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .info-value { font-size: 0.92rem; font-weight: 600; }
    .status-badge { padding: 0.35rem 0.8rem; border-radius: 20px; font-size: 0.76rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
    .status-pending { background: rgba(251, 191, 36, 0.15); color: #fbbf24; border: 1px solid rgba(251, 191, 36, 0.3); }
    .status-confirmed { background: rgba(59, 130, 246, 0.15); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.3); }
    .status-shipped { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; border: 1px solid rgba(139, 92, 246, 0.3); }
    .status-delivered { background: rgba(22, 163, 74, 0.15); color: #16a34a; border: 1px solid rgba(22, 163, 74, 0.3); }
    .status-cancelled { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
    .status-return-requested { background: rgba(255, 193, 7, 0.15); color: #ff6b35; border: 1px solid rgba(255, 193, 7, 0.3); }
    .status-returned { background: rgba(249, 115, 22, 0.15); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.3); }
    .status-partially-returned { background: rgba(168, 85, 247, 0.15); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.3); }
    .btn-view { padding: 0.65rem 1.5rem; background: var(--accent); color: #fff; text-decoration: none; border-radius: 8px; font-size: 0.84rem; font-weight: 600; transition: background 0.15s; display: inline-flex; align-items: center; gap: 0.5rem; }
    .btn-view:hover { background: var(--accent2); }
    .empty-orders { text-align: center; padding: 5rem 2rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius2); }
    .empty-orders i { font-size: 3rem; color: var(--muted2); margin-bottom: 1rem; }
    .empty-orders h3 { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem; }
    .empty-orders p { font-size: 0.84rem; color: var(--muted); margin-bottom: 1.8rem; }
    .pagination { display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem; }
    .page-btn { padding: 0.5rem 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; color: var(--text); text-decoration: none; font-size: 0.84rem; transition: background 0.15s; }
    .page-btn:hover { background: var(--surface2); }
    .page-btn.active { background: var(--accent); border-color: var(--accent); }
    .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    @media (max-width: 900px) {
      .page-wrap { padding: 4rem 1.25rem 3rem; }
      .page-title { font-size: 2.2rem; }
    }
    @media (max-width: 768px) {
      .order-header { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
      .order-body { grid-template-columns: 1fr; gap: 1.25rem; }
      .order-info { flex-direction: column; gap: 1rem; }
      .btn-view { width: 100%; justify-content: center; }
    }
    @media (max-width: 480px) {
      .search-form { flex-direction: column; }
      .search-btn { width: 100%; }
      .clear-search { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-wrap">
    <%- include('partials/breadcrumb', { breadcrumbs: [
      { name: 'Home', url: '/home' },
      { name: 'My Orders' }
    ] }) %>
    
    <h1 class="page-title">My Orders <em>—</em></h1>
    <p class="page-subtitle">Track and manage your orders</p>

    <div class="search-bar">
      <form action="/orders" method="GET" class="search-form">
        <input type="text" name="search" class="search-input" placeholder="Search by Order ID" value="<%= search %>">
        <button type="submit" class="search-btn"><i class="fa fa-search"></i> Search</button>
        <% if (search) { %>
          <a href="/orders" class="clear-search"><i class="fa fa-times"></i> Clear</a>
        <% } %>
      </form>
    </div>


    <% if (orders.length === 0) { %>
      <div class="empty-orders">
        <i class="fa fa-box-open"></i>
        <% if (search) { %>
          <h3>No orders found</h3>
          <p>No orders found for "<%= search %>". Please try a different search term.</p>
          <a href="/orders" class="btn-view"><i class="fa fa-arrow-left"></i> View All Orders</a>
        <% } else { %>
          <h3>No orders found</h3>
          <p>You haven't placed any orders yet. Start shopping to see your orders here.</p>
          <a href="/products" class="btn-view"><i class="fa fa-arrow-left"></i> Continue Shopping</a>
        <% } %>
      </div>
    <% } else { %>
      <% orders.forEach(order => { %>
        <div class="order-card">
          <div class="order-header">
            <div>
              <div class="order-id"><%= order.order_id %></div>
              <div class="order-date">Ordered on <%= new Date(order.order_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></div>
            </div>
            <span class="status-badge status-<%= order.order_status.toLowerCase().replace(/\s+/g, '-') %>"><%= order.order_status %></span>
          </div>
          <div class="order-body">
            <div class="order-info">
              <div class="info-item">
                <span class="info-label">Total Amount</span>
                <span class="info-value">₹<%= (order.final_amount || order.total_amount).toLocaleString('en-IN') %></span>
              </div>
              <div class="info-item">
                <span class="info-label">Items</span>
                <span class="info-value"><%= order.items.length %> item(s)</span>
              </div>
              <div class="info-item">
                <span class="info-label">Payment</span>
                <span class="info-value"><%= order.payment_method %></span>
              </div>
            </div>
            <a href="/orders/<%= order._id %>" class="btn-view">
              View Details <i class="fa fa-arrow-right"></i>
            </a>
          </div>
        </div>
      <% }) %>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (hasPrevPage) { %>
            <a href="/orders?page=<%= currentPage - 1 %>&search=<%= search %>" class="page-btn">Previous</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/orders?page=<%= i %>&search=<%= search %>" class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          <% if (hasNextPage) { %>
            <a href="/orders?page=<%= currentPage + 1 %>&search=<%= search %>" class="page-btn">Next</a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
