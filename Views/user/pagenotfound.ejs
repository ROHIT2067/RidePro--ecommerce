<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found</title>
    <link rel="stylesheet" href="/Styles/pagenotfound.css">
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-left">404</div>
        <div class="logo">
            <div class="logo-circle">R</div>
        </div>
        <div class="nav-right">
            <a href="/search" class="nav-item">
                <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                <span>Search</span>
            </a>
            <a href="/login" class="nav-item">
                <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                </svg>
                <span>Login</span>
                <svg class="dropdown-arrow" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        <div class="content-header">
            <div class="breadcrumb">RidePRO > 404</div>
            <h1>Page Not Found</h1>
        </div>

        <div class="not-found-container">
            <div class="not-found-code">404</div>
            <div class="not-found-title">
                <%= typeof title !== 'undefined' ? title : 'Oops! This page is missing.' %>
            </div>
            <p class="not-found-message">
                <%= typeof message !== 'undefined'
                    ? message
                    : 'The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.' %>
            </p>

            <div class="not-found-actions">
                <div class="primary-btn">
                    <form action="/" method="GET">
                        <button type="submit">Back to Home</button>
                    </form>
                </div>
                <div class="secondary-link">
                    <a href="/support">Go to Support Center</a>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
     <%- include('partials/footer') %>
</body>
</html>