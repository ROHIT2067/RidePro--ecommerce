<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Edit</title>
    <link rel="stylesheet" href="/styles/login.css">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
</head>

<body>
    <%- include('partials/header') %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <div class="breadcrumb">RidePRO > Account Edit</div>
                <h1>Enter Your Current Email</h1>
            </div>

            <div class="login-form-container">

                <!-- Login Form -->
                <form action="/emailVerify" method="POST" id="loginForm">
                    <!-- Email Field -->
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required <% if (typeof loginErr !=='undefined' &&
                            loginErr) { %>class="error"<% } %>
                            />
                            <% if (typeof emailErr !=='undefined' && emailErr) { %>
                                <div class="field-error">
                                    <%= emailErr %>
                                </div>
                                <% } %>
                    </div>

                    <!-- Login Button -->
                    <button type="submit" class="submit-btn">Sent OTP</button>
                </form>
            </div>
        </main>

        <!-- Footer -->
        <%- include('partials/footer') %>
</body>

</html>