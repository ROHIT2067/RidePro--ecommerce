<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password | RidePro</title>
    <link rel="stylesheet" href="/Styles/profile.css" />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <%- include('partials/header') %>

    <main class="main-content">
      <div class="content-header">
        <div class="breadcrumb">RidePro &gt; My Account</div>
        <h1>My Account</h1>
      </div>

      <section class="account-layout">
        <!-- Sidebar -->
       <%- include('partials/sidebar') %>

        <!-- Main Content -->
        <div class="account-main">
          <h2>Change Password</h2>

          <form class="account-details-form" method="POST" action="/account/password">

  <div class="form-group">
  <label>Current Password</label>

  <div style="position: relative;">
    <input 
      type="password" 
      id="currentPassword" 
      name="currentPassword" 
      placeholder="Enter current password" 
      required
      style="padding-right: 40px;"
    />

    <span 
      id="toggleCurrentPassword"
      style="
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        display: flex;
        align-items: center;
      "
      aria-label="Toggle current password visibility"
    >
      <svg id="eyeIconCurrent" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z"/>
      </svg>
    </span>
  </div>

  <% if (typeof oldPassErr !== 'undefined' && oldPassErr) { %>
    <div class="field-error"><%= oldPassErr %></div>
  <% } %>
</div>

<div class="form-group">
  <label>New Password</label>

  <div style="position: relative;">
    <input 
      type="password" 
      id="newPassword" 
      name="newPassword" 
      placeholder="Enter new password" 
      required
      style="padding-right: 40px;"
    />

    <span 
      id="toggleNewPassword"
      style="
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        display: flex;
        align-items: center;
      "
      aria-label="Toggle new password visibility"
    >
      <svg id="eyeIconNew" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z"/>
      </svg>
    </span>
  </div>
</div>

<div class="form-group">
  <label>Confirm New Password</label>

  <div style="position: relative;">
    <input 
      type="password" 
      id="confirmPassword" 
      name="confirmPassword" 
      placeholder="Confirm new password" 
      required
      style="padding-right: 40px;"
    />

    <span 
      id="toggleConfirmPassword"
      style="
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        display: flex;
        align-items: center;
      "
      aria-label="Toggle confirm password visibility"
    >
      <svg id="eyeIconConfirm" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z"/>
      </svg>
    </span>
  </div>

  <% if (typeof newPassErr !== 'undefined' && newPassErr) { %>
    <div class="field-error"><%= newPassErr %></div>
  <% } %>
</div>

  <button type="submit" class="btn-save">Change Password</button>
  <a href="/account" class="btn-cancel">Cancel</a>

</form>


          
        </div>
      </section>
    </main>

    <!-- Footer -->
     <%- include('partials/footer') %>
     
  <script>
  const currentPath = window.location.pathname;
  
  // Remove all active classes
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    link.classList.remove('active');
  });
  
  // Add active class - with better matching
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    const linkHref = link.getAttribute('href');
    
    // Exact match OR current path starts with the link (for nested routes)
    if (linkHref === currentPath || 
        (linkHref !== '/' && linkHref !== '/account' && currentPath.startsWith(linkHref))) {
      link.classList.add('active');
    }
  });
  
  // Special case: if we're on /account, highlight Account Detail
  if (currentPath === '/account') {
    document.querySelector('a[href="/account"]').classList.add('active');
  }
</script>
<script>
  function setupToggle(inputId, toggleId, iconId) {
    const input = document.getElementById(inputId);
    const toggle = document.getElementById(toggleId);
    const icon = document.getElementById(iconId);

    toggle.addEventListener("click", () => {
      const isHidden = input.type === "password";
      input.type = isHidden ? "text" : "password";

      icon.innerHTML = isHidden
        ? '<path d="M1.5 1.5l21 21M9.53 9.53A3 3 0 0012 15a3 3 0 002.47-5.47M12 5c-7.633 0-12 7-12 7a21.77 21.77 0 005.17 5.17M18.83 18.83A21.77 21.77 0 0024 12s-4.367-7-12-7a11.9 11.9 0 00-3.29.45" />'
        : '<path d="M12 5c-7.633 0-12 7-12 7s4.367 7 12 7 12-7 12-7-4.367-7-12-7zm0 12c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5zm0-8c-1.654 0-3 1.346-3 3s1.346 3 3 3 3-1.346 3-3-1.346-3-3-3z"/>';
    });
  }

  setupToggle("currentPassword", "toggleCurrentPassword", "eyeIconCurrent");
  setupToggle("newPassword", "toggleNewPassword", "eyeIconNew");
  setupToggle("confirmPassword", "toggleConfirmPassword", "eyeIconConfirm");
</script>
  </body>
</html>
