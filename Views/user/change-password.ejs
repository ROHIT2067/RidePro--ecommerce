<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password | RidePro</title>
    <link rel="stylesheet" href="/Styles/profile.css" />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="header-left">Account Details</div>

      <a href="/" class="logo">
        <div class="logo-circle">R</div>
      </a>

      <div class="nav-right">
        <a class="nav-item"><i class="fa fa-search nav-icon"></i> Search</a>
        <a href="/login" class="nav-item">
          <svg class="nav-icon" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
              clip-rule="evenodd"
            />
          </svg>
          <span><%= currentUser ? currentUser.username : "Guest" %></span>
        </a>
        <a class="nav-item"><i class="fa fa-shopping-cart nav-icon"></i></a>
      </div>
    </header>

    <main class="main-content">
      <div class="content-header">
        <div class="breadcrumb">RidePro &gt; My Account</div>
        <h1>My Account</h1>
      </div>

      <section class="account-layout">
        <!-- Sidebar -->
       <%- include('partials/sidebar') %>

        <!-- Main Content -->
        <div class="account-main">
          <h2>Change Password</h2>

          <form class="account-details-form" method="POST" action="/account/password">

  <div class="form-group">
    <label>Current Password</label>
    <input type="password" name="currentPassword" placeholder="Enter current password" required>
    <% if (typeof oldPassErr !== 'undefined' && oldPassErr) { %>
      <div class="field-error"><%= oldPassErr %></div>
    <% } %>
  </div>

  <div class="form-group">
    <label>New Password</label>
    <input type="password" name="newPassword" placeholder="Enter new password" required>
  </div>

  <div class="form-group">
    <label>Confirm New Password</label>
    <input type="password" name="confirmPassword" placeholder="Confirm new password" required>
    <% if (typeof newPassErr !== 'undefined' && newPassErr) { %>
      <div class="field-error"><%= newPassErr %></div>
    <% } %>
  </div>

  <button type="submit" class="btn-save">Change Password</button>
  <a href="/account" class="btn-cancel">Cancel</a>

</form>


          <div class="pagination">
            <button class="pagination-btn">&lt;</button>
            <button class="pagination-btn active">01</button>
            <button class="pagination-btn">02</button>
            <button class="pagination-btn">03</button>
            <button class="pagination-btn">04</button>
            <button class="pagination-btn">05</button>
            <button class="pagination-btn">&gt;</button>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-section">
          <h3>STORE</h3>
          <ul>
            <li><a href="#">Protective Gear</a></li>
            <li><a href="#">Performance Layers</a></li>
            <li><a href="#">Luggage</a></li>
            <li><a href="#">Accessories</a></li>
            <li><a href="#">Lifestyle Merch</a></li>
          </ul>
        </div>

        <div class="footer-section">
          <h3>SUPPORT</h3>
          <ul>
            <li><a href="#">Shipping Policy</a></li>
            <li><a href="#">Warranty</a></li>
            <li><a href="#">Refund / Exchange Policy</a></li>
            <li><a href="#">Care Instructions</a></li>
            <li><a href="#">Wingman Insurance</a></li>
            <li><a href="#">Terms Of Service</a></li>
            <li><a href="#">Privacy Policy</a></li>
          </ul>
        </div>

        <div class="footer-section">
          <h3>CONTACT US</h3>
          <p>Contact Number: 07795688316</p>
          <p>Mon-Fri 11:00 AM to 4:30 PM</p>
          <a href="#">Customer Support</a>
        </div>

        <div class="footer-section">
          <h3>CAREERS</h3>
          <a href="#">Join #TeamRYNCX</a>
        </div>

        <div class="footer-section">
          <h3>LOCATION</h3>
          <p>Rync Gear HQ</p>
          <p>1107, Kohinoor Square</p>
          <p>Mumbai, Maharashtra</p>
          <p>+91 7795688314</p>
        </div>
      </div>

      <div class="footer-bottom">
        <span></span>
        <div class="social-icons">
          <i class="fa-brands fa-x-twitter social-icon"></i>
          <i class="fa-brands fa-facebook social-icon"></i>
          <i class="fa-brands fa-instagram social-icon"></i>
          <i class="fa-brands fa-youtube social-icon"></i>
        </div>
      </div>
    </footer>
  <script>
  const currentPath = window.location.pathname;
  
  // Remove all active classes
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    link.classList.remove('active');
  });
  
  // Add active class - with better matching
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    const linkHref = link.getAttribute('href');
    
    // Exact match OR current path starts with the link (for nested routes)
    if (linkHref === currentPath || 
        (linkHref !== '/' && linkHref !== '/account' && currentPath.startsWith(linkHref))) {
      link.classList.add('active');
    }
  });
  
  // Special case: if we're on /account, highlight Account Detail
  if (currentPath === '/account') {
    document.querySelector('a[href="/account"]').classList.add('active');
  }
</script>
  </body>
</html>
